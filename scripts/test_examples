#!/usr/bin/env bash
set -euo pipefail

MODE="debug"
PEG_MODE=""
for arg in "$@"; do
  case "$arg" in
    debug|release) MODE="$arg" ;;
    naive|shared) PEG_MODE="$arg" ;;
    *) echo "error: unknown argument: $arg" >&2; exit 1 ;;
  esac
done

if [ -n "$PEG_MODE" ]; then
  PEG_MODES=("$PEG_MODE")
else
  PEG_MODES=(naive shared)
fi

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
NEST="$ROOT/build/${MODE}/nest"
CC="${CC:-clang}"
# Note: -mllvm --enable-gvn-memdep=false works around a clang crash on large
# PEG grammars at -O2. See README.md "Known issues".
CFLAGS="${CFLAGS:--std=c23 -O2 -mllvm --enable-gvn-memdep=false}"
WORKDIR="$ROOT/build/test_examples"
rm -rf "$WORKDIR"
mkdir -p "$WORKDIR"

if [ ! -x "$NEST" ]; then
  echo "error: $NEST not found, run: ruby config.rb $MODE && ninja" >&2
  exit 1
fi

# ANSI colors (disabled if stdout is not a tty or NO_COLOR is set)
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_CMD=$'\033[36m'    # cyan for executed commands
  C_INPUT=$'\033[33m'  # yellow for input files
  C_RESET=$'\033[0m'
else
  C_CMD=""
  C_INPUT=""
  C_RESET=""
fi

# run: echo and execute a command
run() {
  echo "${C_CMD}$*${C_RESET}"
  "$@"
}

pass=0
fail=0

validate_parsed_tokens() {
  local expected="$1"
  local actual_file="$2"
  local report_file="$3"

  ruby - "$expected" "$actual_file" >"$report_file" <<'RUBY'
expected = File.read(ARGV[0])
actual = File.read(ARGV[1])

# Only success cases must have complete parse coverage. Error cases have
# diagnostic lines before the first separator in their expected output.
expected_errors = expected.split("------\n", 2)[0]
exit 0 unless expected_errors.strip.empty?

parts = actual.split("------\n", 3)
if parts.length < 3
  puts "parsed token coverage check failed: output does not contain all three sections"
  exit 1
end

token_section = parts[1]
parse_section = parts[2]

tokenizer_tokens = token_section.lines.filter_map do |line|
  match = line.match(/^\s*(\S+)\s+"/)
  match && match[1].start_with?("@") ? match[1] : nil
end

parsed_tokens = parse_section.lines.filter_map do |line|
  name = line.strip.split(/\s+/, 2)[0]
  name&.start_with?("@") ? name : nil
end

exit 0 if tokenizer_tokens == parsed_tokens

puts "parsed token coverage mismatch"
puts "  tokenizer tokens: #{tokenizer_tokens.length}"
puts "  parse tree tokens: #{parsed_tokens.length}"

limit = [tokenizer_tokens.length, parsed_tokens.length].min
mismatch = (0...limit).find { |i| tokenizer_tokens[i] != parsed_tokens[i] }
if mismatch
  puts "  first mismatch at token #{mismatch}: tokenizer=#{tokenizer_tokens[mismatch].inspect}, parse=#{parsed_tokens[mismatch].inspect}"
else
  puts "  first mismatch at token #{limit}: #{tokenizer_tokens.length > parsed_tokens.length ? 'parse tree ended early' : 'parse tree has extra tokens'}"
end

start = [mismatch || limit, 0].max
puts "  tokenizer tail: #{tokenizer_tokens[start, 12].inspect}"
puts "  parse tree tail: #{parsed_tokens[start, 12].inspect}"
exit 1
RUBY
}

for dir in "$ROOT"/test/examples/*/; do
  dir="${dir%/}"
  name=$(basename "$dir")
  grammar="$dir/grammar.nest"
  [ -f "$grammar" ] || continue

  for mode in "${PEG_MODES[@]}"; do
    case_dir="$WORKDIR/${name}_${mode}"
    mkdir -p "$case_dir"

    # Compile grammar (cd into case_dir so outputs land there)
    if ! (cd "$case_dir" && run "$NEST" c "$grammar" -p "$name" -m "$mode") 2>"$case_dir/nest_err"; then
      echo "FAIL $name ($mode): nest c failed"
      cat "$case_dir/nest_err" >&2
      fail=$((fail + 1))
      continue
    fi

    # Compile (use mode-specific binary name to avoid macOS dyld caching issues)
    bin="$case_dir/${name}_${mode}"
    if ! run $CC $CFLAGS "$case_dir/${name}.c" "$case_dir/${name}.ll" -o "$bin" 2>"$case_dir/cc_err"; then
      echo "FAIL $name ($mode): compile failed"
      cat "$case_dir/cc_err" >&2
      fail=$((fail + 1))
      continue
    fi

    # Run each input/expected pair
    for input_file in "$dir"/*.input; do
      [ -f "$input_file" ] || continue
      case_name=$(basename "$input_file" .input)
      expected="$dir/${case_name}.expected"
      [ -f "$expected" ] || continue

      rel_input="${input_file#$ROOT/}"
      echo "${C_INPUT}${rel_input}${C_RESET}"
      actual=$("$bin" "$input_file" 2>&1 || true)
      actual_file="$case_dir/${case_name}.actual"
      printf "%s\n" "$actual" >"$actual_file"

      diff_ok=0
      validate_ok=0
      if diff -u "$expected" "$actual_file" >"$case_dir/${case_name}.diff" 2>&1; then
        diff_ok=1
      fi
      if validate_parsed_tokens "$expected" "$actual_file" "$case_dir/${case_name}.tokens"; then
        validate_ok=1
      fi

      if [ "$diff_ok" -eq 1 ] && [ "$validate_ok" -eq 1 ]; then
        pass=$((pass + 1))
      else
        echo "FAIL $name/$case_name ($mode):"
        if [ "$diff_ok" -ne 1 ]; then
          cat "$case_dir/${case_name}.diff"
        fi
        if [ "$validate_ok" -ne 1 ]; then
          cat "$case_dir/${case_name}.tokens"
        fi
        fail=$((fail + 1))
      fi
    done
  done
done

echo ""
echo "$pass passed, $fail failed"
[ "$fail" -eq 0 ]
