// nest_runner.c.erb — timing harness for nest-generated parsers.
// ERB template. Compiled per grammar via: nest c grammar.nest -p <prefix> -m <mode>
// Then: clang -O2 -mllvm --enable-gvn-memdep=false nest_runner.c <prefix>.ll -o runner
// (the -mllvm flag avoids a clang -O2 crash on large PEG grammars; see README.md)

#include "<%= prefix %>.h"

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <pthread.h>

#define STACK_SIZE (128 * 1024 * 1024) // 128MB stack for deep PEG recursion with -O2 inlining

static double now_sec(void) {
    struct timespec ts;
    clock_gettime(CLOCK_MONOTONIC, &ts);
    return ts.tv_sec + ts.tv_nsec * 1e-9;
}

int32_t <%= prefix %>_next_cp(void* userdata) {
    return ustr_iter_next((UstrIter*)userdata);
}

static int cmp_double(const void* a, const void* b) {
    double da = *(const double*)a;
    double db = *(const double*)b;
    return (da > db) - (da < db);
}

typedef struct {
    const char* input_path;
    int iterations;
    int result;
} RunnerArgs;

static void* runner_thread(void* arg) {
    RunnerArgs* args = (RunnerArgs*)arg;
    const char* input_path = args->input_path;
    int iterations = args->iterations;

    // Read input file
    FILE* f = fopen(input_path, "rb");
    if (!f) { perror(input_path); args->result = 1; return NULL; }
    char* src = ustr_from_file(f);
    fclose(f);
    if (!src) { fprintf(stderr, "failed to read %s\n", input_path); args->result = 1; return NULL; }
    int32_t file_size = ustr_bytesize(src);

    // Warm up: 3 iterations
    for (int i = 0; i < 3; i++) {
        ParseContext ctx = {0};
        ParseResult res = <%= prefix %>_parse(&ctx, src);
        <%= prefix %>_cleanup(&res);
    }

    // Timed iterations
    double* times = malloc(sizeof(double) * (size_t)iterations);
    for (int i = 0; i < iterations; i++) {
        ParseContext ctx = {0};
        double t0 = now_sec();
        ParseResult res = <%= prefix %>_parse(&ctx, src);
        double t1 = now_sec();
        times[i] = (t1 - t0) * 1e6; // microseconds
        <%= prefix %>_cleanup(&res);
    }

    // Compute median
    qsort(times, (size_t)iterations, sizeof(double), cmp_double);
    double median_us = times[iterations / 2];

    // One more parse to collect stats
    ParseContext ctx = {0};
    ParseResult res = <%= prefix %>_parse(&ctx, src);
    size_t token_count = res.main.tc ? darray_size(res.main.tc->tokens) : 0;
    size_t chunk_count = res.tt ? darray_size(res.tt->table) : 0;
    size_t error_count = res.errors ? darray_size(res.errors) : 0;
    if (error_count > 0) {
        for (size_t i = 0; i < error_count; i++) {
            fprintf(stderr, "parse error: %s (offset %d)\n",
                    res.errors[i].message ? res.errors[i].message : "(null)",
                    res.errors[i].cp_offset);
        }
    }
    <%= prefix %>_cleanup(&res);

    // CSV: parse_us,size_bytes,token_count,chunk_count
    printf("%.1f,%d,%d,%d\n", median_us, file_size, token_count, chunk_count);

    free(times);
    ustr_del(src);
    args->result = 0;
    return NULL;
}

int main(int argc, char** argv) {
    if (argc < 3) {
        fprintf(stderr, "usage: %s <input_file> <iterations>\n", argv[0]);
        return 1;
    }

    RunnerArgs args = { .input_path = argv[1], .iterations = atoi(argv[2]), .result = 0 };
    if (args.iterations < 1) args.iterations = 1;

    pthread_t th;
    pthread_attr_t attr;
    pthread_attr_init(&attr);
    pthread_attr_setstacksize(&attr, STACK_SIZE);
    pthread_create(&th, &attr, runner_thread, &args);
    pthread_join(th, NULL);
    pthread_attr_destroy(&attr);
    return args.result;
}
