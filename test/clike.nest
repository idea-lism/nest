[[vpa]]
%ignore @space

*keywords = @{
  "if"
  "else"
  "while"
}

*common = {
  /[a-zA-Z_]\w*/ @ident
  /\d+/ @number
  /\s+/ @space
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /\// @slash
  /=/ @assign
  /;/ @semi
  /\(/ @lparen
  /\)/ @rparen
  /==/ @eq
  /!=/ @ne
  /</ @lt
  />/ @gt
  /<=/ @le
  />=/ @ge
}

main = {
  *keywords
  block
  *common
}

block = /{/ .begin @lbrace {
  /}/ @rbrace .end
  *keywords
  block
  *common
}

[[peg]]
main = stmt*
stmt = [
  if_stmt
  while_stmt
  assign_stmt
]
if_stmt = "if" @lparen expr @rparen block else_block?
else_block = "else" block
while_stmt = "while" @lparen expr @rparen block
block = @lbrace stmt* @rbrace
assign_stmt = @ident @assign expr @semi
expr = cmp
cmp = arith cmp_tail?
cmp_tail = cmpop arith
cmpop = [
  @eq
  @ne
  @lt
  @gt
  @le
  @ge
]
arith = term+<addop>
addop = [
  @plus
  @minus
]
term = factor+<mulop>
mulop = [
  @star
  @slash
]
factor = [
  @number
  @ident
  @lparen expr @rparen
]
