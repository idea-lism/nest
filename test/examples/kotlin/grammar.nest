# Kotlin grammar in nest syntax
# Based on the official Kotlin grammar specification
# https://kotlinlang.org/grammar/

[[vpa]]
%ignore @space @comment

# Keywords (order matters for VPA: longer matches first by the DFA)
*keywords = @{
  "package"
  "import"
  "class"
  "interface"
  "fun"
  "object"
  "val"
  "var"
  "typealias"
  "constructor"
  "by"
  "companion"
  "init"
  "this"
  "super"
  "typeof"
  "where"
  "if"
  "else"
  "when"
  "try"
  "catch"
  "finally"
  "for"
  "do"
  "while"
  "throw"
  "return"
  "continue"
  "break"
  "as"
  "is"
  "in"
  "out"
  "dynamic"
  "public"
  "private"
  "protected"
  "internal"
  "enum"
  "sealed"
  "annotation"
  "data"
  "inner"
  "tailrec"
  "operator"
  "infix"
  "inline"
  "external"
  "suspend"
  "override"
  "abstract"
  "final"
  "open"
  "const"
  "lateinit"
  "vararg"
  "noinline"
  "crossinline"
  "reified"
  "expect"
  "actual"
  "true"
  "false"
  "null"
  "get"
  "set"
  "field"
  "property"
  "receiver"
  "param"
  "setparam"
  "delegate"
  "file"
}

main = {
  *keywords
  /\/\*([^*]|\*+[^*\/])*\*+\// @comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t]+/ @space
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /\|\|/ @disj
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /,/ @comma
  /:/ @colon
  /;/ @semi
  /\./ @dot
  /\?/ @quest
  /!/ @excl
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /\// @slash
  /@/ @at
}

block = /[{]/ .begin @lbrace {
  *keywords
  /\/\*([^*]|\*+[^*\/])*\*+\// @comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t]+/ @space
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /\|\|/ @disj
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /[}]/ @rbrace .end
  /,/ @comma
  /:/ @colon
  /;/ @semi
  /\./ @dot
  /\?/ @quest
  /!/ @excl
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /\// @slash
  /@/ @at
}

str = /"/ .begin @str_open {
  /"/ @str_close .end
  str_interp
  /\\[tbnr'"\\$]/ @str_escape
  /\\u\h\h\h\h/ @str_unicode
  /\$[A-Za-z_]\w*/ @str_ref
  /[^"\\$\r\n]+/ @str_text
  /\$/ @str_text
}

str_interp = /\$[{]/ .begin @str_expr_open {
  *keywords
  /\/\*([^*]|\*+[^*\/])*\*+\// @comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t]+/ @space
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /\|\|/ @disj
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /[}]/ @str_expr_close .end
  /,/ @comma
  /:/ @colon
  /\./ @dot
  /\?/ @quest
  /!/ @excl
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /\// @slash
  /@/ @at
}

multiline_str = /"""/ .begin @ml_str_open {
  /"{0,2}"""/ @ml_str_close .end
  ml_str_interp
  /\$[A-Za-z_]\w*/ @str_ref
  /"{1,2}/ @str_text
  /[^"$]+/ @str_text
  /\$/ @str_text
}

ml_str_interp = /\$[{]/ .begin @str_expr_open {
  *keywords
  /\/\*([^*]|\*+[^*\/])*\*+\// @comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t]+/ @space
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /\|\|/ @disj
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /[}]/ @str_expr_close .end
  /,/ @comma
  /:/ @colon
  /\./ @dot
  /\?/ @quest
  /!/ @excl
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /\// @slash
  /@/ @at
}

char_lit = /'/ .begin @char_open {
  /'/ @char_close .end
  /\\[tbnr'"\\$]/ @str_escape
  /\\u\h\h\h\h/ @str_unicode
  /[^'\\\r\n]/ @str_text
}

[[peg]]

# Newline handling:
# - @nl is visible to PEG (not %ignore'd).
# - @space / @comment are %ignore'd, so "spaces only" gaps are implicit between
#   tokens and need no explicit rule.
# - `_` matches optional newlines (packcc's `__*`). Use it where newlines are
#   allowed, e.g. after a binary operator.
# - `semi` matches one or more statement terminators (newline or `;`).
# - Binary operator separators follow packcc: no newline allowed on the left of
#   the operator (so newlines terminate the expression), newlines allowed on
#   the right before the next operand.
_ = @nl*
semi = semi_item+
semi_item = [
  @semi
  @nl
]
comma_sep = _ @comma _

# Operator separators (`sep` in `+<sep>` must be a single rule).
# Shape: `operator _` — no `_` before the operator, so a trailing newline on
# the previous operand terminates the expression instead of being consumed.
disj_sep = @disj _
conj_sep = @conj _
elvis_sep = @elvis _
range_sep = @range _
eq_sep = equality_op _
cmp_sep = comparison_op _
add_sep = additive_op _
mul_sep = mult_op _

# Kotlin file structure
# Top-level: a list of file_parts separated by optional semis/newlines, with
# optional leading and trailing blank lines.
main = _ top_list? _
top_list = file_part+<semi>

file_part = [
  package_header
  import_header
  declaration
]

# Package & import
package_header = "package" identifier
import_header = "import" identifier import_suffix?
import_suffix = [
  @dot @star
  "as" simple_id
]

# Declarations
declaration = [
  class_decl
  object_decl
  fun_decl
  property_decl
  type_alias
]

type_alias = modifier* "typealias" _ simple_id nl_type_params? _ @assign _ type

# Class
class_decl = modifier* class_kw _ simple_id nl_type_params? nl_primary_ctor? nl_delegation? nl_type_constraints? nl_class_body?
# Helper rules: `nl_X?` means "optional newlines followed by X". When X is
# absent, the newlines aren't consumed either — which is essential for
# statement separation (otherwise a trailing `_` would eat the NL that a
# later `semi` needs).
nl_type_params = _ type_params
nl_primary_ctor = _ primary_constructor
nl_delegation = _ delegation
nl_type_constraints = _ type_constraints
nl_class_body = _ class_body
nl_receiver_type_dot = _ receiver_type_dot
nl_return_type = _ return_type
nl_fun_body = _ fun_body
nl_property_init = _ property_init
nl_property_accessors = _ property_accessors
class_kw = [
  "class"
  "interface"
]
primary_constructor = modifier* "constructor"? _ class_params
class_params = @lparen _ class_param*<comma_sep> _ @rparen
class_param = modifier* val_or_var? simple_id _ @colon _ type _ default_value?
val_or_var = [
  "val"
  "var"
]
default_value = @assign _ expression
delegation = @colon _ delegation_spec+<comma_sep>
delegation_spec = [
  user_type _ value_args : ctor_invocation
  user_type _ "by" _ expression : explicit_delegation
  user_type : type_spec
  fun_type : fun_type_spec
]
class_body = _ block
block = @lbrace _ statements _ @rbrace

# Class members (parsed as statements inside class bodies)
companion_obj = modifier* "companion" _ "object" nl_simple_id? nl_delegation? nl_class_body?
nl_simple_id = _ simple_id
secondary_constructor = modifier* "constructor" _ fun_value_params nl_delegation_call? nl_block?
nl_delegation_call = _ delegation_call
nl_block = _ block
delegation_call = @colon _ [
  "this" _ value_args
  "super" _ value_args
]
anon_init = "init" _ block

# Functions
fun_decl = modifier* "fun" nl_type_params? nl_receiver_type_dot? _ simple_id _ fun_value_params nl_return_type? nl_type_constraints? nl_fun_body?
fun_value_params = @lparen _ fun_value_param*<comma_sep> _ @rparen
fun_value_param = modifier* parameter _ default_value?
parameter = simple_id _ @colon _ type
return_type = @colon _ type
fun_body = [
  block
  @assign _ expression
]
# `receiverTypeAndDot <- (typeModifiers _*)? (nullableType __* DOT __* /
# parenthesizedType __* DOT __* / (simpleUserType __* DOT __*)+)` (packcc).
# The last `DOT` belongs to the receiver, and a final `simpleIdentifier`
# follows it — crucially the trailing dot means the inner user_type must
# NOT greedily consume the identifier after the dot.
receiver_type_dot = type_modifier* receiver_type_dot_tail
receiver_type_dot_tail = [
  nullable_type _ @dot _
  paren_type _ @dot _
  user_type_dot_list
]
user_type_dot_list = simple_user_type_dot+
simple_user_type_dot = simple_user_type _ @dot _

# Properties
property_decl = modifier* val_or_var nl_type_params? nl_receiver_type_dot? _ var_decl nl_type_constraints? nl_property_init? nl_property_accessors?
var_decl = [
  @lparen _ variable_decl+<comma_sep> _ @rparen
  variable_decl
]
variable_decl = simple_id type_annotation?
type_annotation = _ @colon _ type
property_init = [
  @assign _ expression
  "by" _ expression
]
property_accessors = [
  getter _ setter?
  setter _ getter?
]
getter = modifier* "get" _ @lparen _ @rparen _ return_type? _ fun_body
setter = modifier* "set" _ @lparen _ setter_param _ @rparen _ return_type? _ fun_body
setter_param = modifier* simple_id _ type_annotation?

# Object
object_decl = modifier* "object" _ simple_id nl_delegation? nl_class_body?

# Enum bodies use the class-member grammar for now; the packcc grammar has a
# dedicated `enumClassBody` with comma-separated entries that we don't model yet.

# Types
type = type_modifier* type_inner quest*
type_inner = [
  fun_type
  nullable_type
  paren_type
  type_ref
]
type_ref = [
  user_type
  "dynamic"
]
nullable_type = [
  type_ref quest+
  paren_type quest+
]
quest = [
  @quest
]
user_type = simple_user_type+<@dot>
simple_user_type = simple_id nl_type_args?
nl_type_args = _ type_args
type_args = @langle _ type_projection+<comma_sep> _ @rangle
type_projection = [
  type_projection_modifier* type
  @star
]
type_projection_modifier = [
  variance_modifier
  annotation
]
fun_type = receiver_type_prefix? fun_type_params _ @arrow _ type
receiver_type_prefix = receiver_type @dot _
fun_type_params = @lparen _ fun_type_param*<comma_sep> _ @rparen
fun_type_param = [
  parameter
  type
]
paren_type = @lparen _ type _ @rparen
receiver_type = type_modifier* receiver_type_inner
receiver_type_inner = [
  nullable_type
  paren_type
  type_ref
]
type_modifier = [
  annotation
  "suspend" _
]

# Type parameters & constraints
type_params = @langle _ type_param+<comma_sep> _ @rangle
type_param = type_param_modifier* simple_id _ type_bound?
type_bound = @colon _ type
type_constraints = "where" _ type_constraint+<comma_sep>
type_constraint = annotation* simple_id _ @colon _ type
variance_modifier = [
  "in"
  "out"
]
type_param_modifier = [
  "reified"
  variance_modifier
  annotation
]

statements = stmt_list?
stmt_list = statement stmt_cont* semi?
stmt_cont = semi statement
statement = [
  declaration
  companion_obj
  secondary_constructor
  anon_init
  when_entry
  assignment
  loop_stmt
  expression
]
assignment = [
  directly_assignable _ assign_op _ expression
  assignable _ assign_op _ expression
]
assign_op = [
  @assign
  @plus_assign
  @minus_assign
  @star_assign
  @slash_assign
  @mod_assign
]
loop_stmt = [
  for_stmt
  while_stmt
  do_while_stmt
]
for_stmt = "for" _ @lparen _ annotation* for_var _ "in" _ expression _ @rparen nl_control_body?
for_var = [
  variable_decl
  @lparen _ variable_decl+<comma_sep> _ @rparen
]
while_stmt = "while" _ @lparen _ expression _ @rparen _ control_body
do_while_stmt = "do" nl_control_body? _ "while" _ @lparen _ expression _ @rparen
control_body = [
  block
  statement
]

# Expressions
# For binary/infix/postfix chains, newlines on the LEFT of an operator must
# terminate the expression (so the next line starts a new statement); newlines
# on the RIGHT of an operator are allowed so line continuations work. This
# mirrors packcc's `_*` (no NL) vs `__*` (allow NL) distinction.
expression = disjunction
disjunction = conjunction+<disj_sep>
conjunction = equality+<conj_sep>
equality = comparison+<eq_sep>
equality_op = [
  @eqeqeq
  @eqeq
  @noteqeq
  @noteq
]
comparison = generic_call_like+<cmp_sep>
comparison_op = [
  @le
  @ge
  @langle
  @rangle
]
generic_call_like = infix_op call_suffix*
infix_op = elvis_expr infix_tail*
infix_tail = [
  in_op _ elvis_expr : in_check
  is_op _ type : is_check
  simple_id _ elvis_expr : named_check
]
in_op = [
  "in"
  @not_in
]
is_op = [
  "is"
  @not_is
]
elvis_expr = infix_fn_call+<elvis_sep>
infix_fn_call = range_expr infix_fn_tail*
infix_fn_tail = simple_id _ range_expr
range_expr = additive_expr+<range_sep>
additive_expr = mult_expr+<add_sep>
additive_op = [
  @plus
  @minus
]
mult_expr = as_expr+<mul_sep>
mult_op = [
  @star
  @slash
  @mod
]
# `asExpression <- prefixUnary (__* asOperator __* type)*` — packcc allows NL on
# BOTH sides of `as`, so we keep `_` on the left too.
as_expr = prefix_unary as_tail*
as_tail = _ as_op _ type
as_op = [
  @as_safe
  "as"
]
prefix_unary = unary_prefix* postfix_unary
unary_prefix = [
  annotation
  label
  prefix_unary_op
]
prefix_unary_op = [
  @incr
  @decr
  @minus
  @plus
  @excl
]
postfix_unary = primary_expr postfix_suffix*
postfix_suffix = [
  @incr
  @decr
  type_args
  call_suffix
  index_suffix
  nav_suffix
]
directly_assignable = [
  postfix_unary assignable_suffix
  simple_id
]
assignable = prefix_unary
assignable_suffix = [
  nav_suffix
  type_args
  index_suffix
]
index_suffix = @lbracket _ expression+<comma_sep> _ @rbracket
nav_suffix = member_access_op _ nav_target
member_access_op = [
  @safe_dot
  @dot
  @coloncolon
]
nav_target = [
  simple_id
  paren_expr
  "class"
]
# callSuffix: all internal gaps are `_*` (no NL), mirroring packcc. A NL
# before the `{` of a trailing lambda would terminate the expression and start
# a new statement.
call_suffix = [
  type_args? value_args annotated_lambda : args_lambda
  type_args? value_args : args_only
  type_args annotated_lambda : type_lambda
  annotated_lambda : lambda_only
]
annotated_lambda = annotation* label? lambda_lit
value_args = @lparen _ value_arg*<comma_sep> _ @rparen
value_arg = annotation? named_arg? @star? expression
named_arg = simple_id _ @assign _
lambda_lit = block

# Primary expressions
primary_expr = [
  "this" @at simple_id : this_at
  "this" : this_expr
  "super" @at simple_id : super_at
  "super" type_args? : super_expr
  if_expr
  when_expr
  try_expr
  jump_expr
  paren_expr
  callable_ref
  string_lit
  fun_literal
  object_literal
  collection_lit
  simple_id
  literal_const
]
paren_expr = @lparen _ expression _ @rparen
collection_lit = [
  @lbracket _ expression+<comma_sep> _ @rbracket : non_empty
  @lbracket _ @rbracket : empty
]
literal_const = [
  @float_lit
  @hex_lit
  @bin_lit
  @long_lit
  @unsigned_lit
  @int_lit
  "true"
  "false"
  "null"
  char_lit
]
char_lit = @char_open char_content* @char_close
char_content = [
  @str_escape
  @str_unicode
  @str_text
]

# Strings
string_lit = [
  multi_line_str
  line_str
]
line_str = str
str = @str_open line_str_content* @str_close
line_str_content = [
  str_interp
  @str_escape
  @str_unicode
  @str_ref
  @str_text
]
multi_line_str = multiline_str
multiline_str = @ml_str_open ml_str_content* @ml_str_close
ml_str_content = [
  ml_str_interp
  @str_ref
  @str_text
]
str_interp = @str_expr_open _ expression _ @str_expr_close
ml_str_interp = @str_expr_open _ expression _ @str_expr_close

# Function literals & object literals
fun_literal = [
  lambda_lit
  anon_fun
]
anon_fun = "fun" nl_receiver_type_dot? _ fun_value_params nl_return_type? nl_type_constraints? nl_fun_body?
object_literal = [
  "object" _ @colon _ delegation_spec+<comma_sep> _ class_body : with_delegation
  "object" _ class_body : plain
]

# Control flow
if_expr = "if" _ @lparen _ expression _ @rparen nl_control_body? nl_else_branch?
nl_control_body = _ control_body
nl_else_branch = _ else_branch
else_branch = "else" _ control_body
when_expr = "when" _ when_subject? _ block
when_subject = @lparen _ when_subject_val? expression _ @rparen
when_subject_val = annotation* "val" _ variable_decl _ @assign _
when_entry = [
  when_cond+<comma_sep> _ @arrow _ control_body
  "else" _ @arrow _ control_body
]
when_cond = [
  expression
  in_op _ expression
  is_op _ type
]
try_expr = "try" _ block nl_catch_block* nl_finally_block?
nl_catch_block = _ catch_block
nl_finally_block = _ finally_block
catch_block = "catch" _ @lparen _ annotation* simple_id _ @colon _ type _ @rparen _ block
finally_block = "finally" _ block
jump_expr = [
  "throw" _ expression : throw_expr
  "return" @at simple_id _ expression? : return_at
  "return" _ expression? : return_expr
  "continue" @at simple_id : continue_at
  "continue" : continue_expr
  "break" @at simple_id : break_at
  "break" : break_expr
]
callable_ref = type? @coloncolon _ callable_ref_target
callable_ref_target = [
  simple_id
  "class"
]

# Annotations & labels
annotation = [
  annotation_use_site unescaped_annotation _
  @at unescaped_annotation _
]
annotation_use_site = @at annotation_target @colon
annotation_target = [
  "field"
  "property"
  "get"
  "set"
  "receiver"
  "param"
  "setparam"
  "delegate"
  "file"
]
unescaped_annotation = [
  user_type _ value_args : with_args
  user_type : type_only
]
label = @label_ref

# Modifiers
modifier = [
  class_modifier _
  member_modifier _
  visibility_modifier _
  function_modifier _
  property_modifier _
  inheritance_modifier _
  parameter_modifier _
  platform_modifier _
  annotation
]
class_modifier = [
  "enum"
  "sealed"
  "annotation"
  "data"
  "inner"
]
member_modifier = [
  "override"
  "lateinit"
]
visibility_modifier = [
  "public"
  "private"
  "internal"
  "protected"
]
function_modifier = [
  "tailrec"
  "operator"
  "infix"
  "inline"
  "external"
  "suspend"
]
property_modifier = "const"
inheritance_modifier = [
  "abstract"
  "final"
  "open"
]
parameter_modifier = [
  "vararg"
  "noinline"
  "crossinline"
]
platform_modifier = [
  "expect"
  "actual"
]

# Identifiers
simple_id = [
  !hard_keyword @ident
  soft_keyword
]
hard_keyword = [
  "as"
  "break"
  "class"
  "continue"
  "do"
  "else"
  "for"
  "fun"
  "if"
  "in"
  "interface"
  "is"
  "null"
  "object"
  "package"
  "return"
  "super"
  "this"
  "throw"
  "try"
  "typealias"
  "typeof"
  "val"
  "var"
  "when"
  "while"
  "true"
  "false"
]
soft_keyword = [
  "abstract"
  "annotation"
  "by"
  "catch"
  "companion"
  "constructor"
  "crossinline"
  "data"
  "dynamic"
  "enum"
  "external"
  "final"
  "finally"
  "get"
  "import"
  "infix"
  "init"
  "inline"
  "inner"
  "internal"
  "lateinit"
  "noinline"
  "open"
  "operator"
  "out"
  "override"
  "private"
  "protected"
  "public"
  "reified"
  "sealed"
  "tailrec"
  "set"
  "vararg"
  "where"
  "field"
  "property"
  "receiver"
  "param"
  "setparam"
  "delegate"
  "file"
  "expect"
  "actual"
  "const"
  "suspend"
]

identifier = simple_id+<@dot>
