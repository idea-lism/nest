# Kotlin grammar in nest syntax
# Based on the official Kotlin grammar specification
# https://kotlinlang.org/grammar/

[[vpa]]
%ignore @space @comment

# Keywords (order matters for VPA: longer matches first by the DFA)
*keywords = @{
  "package"
  "import"
  "class"
  "interface"
  "fun"
  "object"
  "val"
  "var"
  "typealias"
  "constructor"
  "by"
  "companion"
  "init"
  "this"
  "super"
  "typeof"
  "where"
  "if"
  "else"
  "when"
  "try"
  "catch"
  "finally"
  "for"
  "do"
  "while"
  "throw"
  "return"
  "continue"
  "break"
  "as"
  "is"
  "in"
  "out"
  "dynamic"
  "public"
  "private"
  "protected"
  "internal"
  "enum"
  "sealed"
  "annotation"
  "data"
  "inner"
  "tailrec"
  "operator"
  "infix"
  "inline"
  "external"
  "suspend"
  "override"
  "abstract"
  "final"
  "open"
  "const"
  "lateinit"
  "vararg"
  "noinline"
  "crossinline"
  "reified"
  "expect"
  "actual"
  "true"
  "false"
  "null"
  "get"
  "set"
  "field"
  "property"
  "receiver"
  "param"
  "setparam"
  "delegate"
  "file"
}

main = {
  /#![^\r\n]*/ @shebang_line
  /return@[A-Za-z_]\w*/ @return_at
  /continue@[A-Za-z_]\w*/ @continue_at
  /break@[A-Za-z_]\w*/ @break_at
  /this@[A-Za-z_]\w*/ @this_at
  /super@[A-Za-z_]\w*/ @super_at
  *keywords
  comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t\f]+/ @space
  /=>/
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /&/ @amp
  /\|\|/ @disj
  /\.\.</ @range_until
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /,/ @comma
  /:/ @colon
  /;;/ @double_semi
  /;/ @semi
  /\./ @dot
  /\?[ \t\f]+/ @quest_ws
  /\?/ @quest_no_ws
  /![ \t\f]+/ @excl_ws
  /!/ @excl_no_ws
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /#/
  /\.\.\./
  /\// @slash
  /@[ \t\f\r\n]+/ @at_post_ws
  /@/ @at_no_ws
  EOF .end
}

comment = /\/\*/ .begin @comment {
  comment
  /\*\// .end
  /[^*\/]+/
  /\*/
  /\//
}

block = /[{]/ .begin @lbrace {
  /#![^\r\n]*/
  /return@[A-Za-z_]\w*/ @return_at
  /continue@[A-Za-z_]\w*/ @continue_at
  /break@[A-Za-z_]\w*/ @break_at
  /this@[A-Za-z_]\w*/ @this_at
  /super@[A-Za-z_]\w*/ @super_at
  *keywords
  comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t\f]+/ @space
  /=>/
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /&/ @amp
  /\|\|/ @disj
  /\.\.</ @range_until
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /[}]/ @rbrace .end
  /,/ @comma
  /:/ @colon
  /;;/ @double_semi
  /;/ @semi
  /\./ @dot
  /\?[ \t\f]+/ @quest_ws
  /\?/ @quest_no_ws
  /![ \t\f]+/ @excl_ws
  /!/ @excl_no_ws
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /#/
  /\.\.\./
  /\// @slash
  /@[ \t\f\r\n]+/ @at_post_ws
  /@/ @at_no_ws
}

str = /"/ .begin @str_open {
  /"/ @str_close .end
  str_interp
  /\\[tbnr'"\\$]/ @str_escape
  /\\u\h\h\h\h/ @str_unicode
  /\$[A-Za-z_]\w*/ @str_ref
  /[^"\\$\r\n]+/ @str_text
  /\$/ @str_text
}

str_interp = /\$[{]/ .begin @str_expr_open {
  /#![^\r\n]*/
  /return@[A-Za-z_]\w*/ @return_at
  /continue@[A-Za-z_]\w*/ @continue_at
  /break@[A-Za-z_]\w*/ @break_at
  /this@[A-Za-z_]\w*/ @this_at
  /super@[A-Za-z_]\w*/ @super_at
  *keywords
  comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t\f]+/ @space
  /=>/
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /&/ @amp
  /\|\|/ @disj
  /\.\.</ @range_until
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /[}]/ @str_expr_close .end
  /,/ @comma
  /:/ @colon
  /;;/ @double_semi
  /;/ @semi
  /\./ @dot
  /\?[ \t\f]+/ @quest_ws
  /\?/ @quest_no_ws
  /![ \t\f]+/ @excl_ws
  /!/ @excl_no_ws
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /#/
  /\.\.\./
  /\// @slash
  /@[ \t\f\r\n]+/ @at_post_ws
  /@/ @at_no_ws
}

multiline_str = /"""/ .begin @ml_str_open {
  /"{0,2}"""/ @ml_str_close .end
  ml_str_interp
  /\$[A-Za-z_]\w*/ @str_ref
  /"{1,2}/ @str_text
  /[^"$]+/ @str_text
  /\$/ @str_text
}

ml_str_interp = /\$[{]/ .begin @str_expr_open {
  /#![^\r\n]*/
  /return@[A-Za-z_]\w*/ @return_at
  /continue@[A-Za-z_]\w*/ @continue_at
  /break@[A-Za-z_]\w*/ @break_at
  /this@[A-Za-z_]\w*/ @this_at
  /super@[A-Za-z_]\w*/ @super_at
  *keywords
  comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t\f]+/ @space
  /=>/
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /&/ @amp
  /\|\|/ @disj
  /\.\.</ @range_until
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /[}]/ @str_expr_close .end
  /,/ @comma
  /:/ @colon
  /;;/ @double_semi
  /;/ @semi
  /\./ @dot
  /\?[ \t\f]+/ @quest_ws
  /\?/ @quest_no_ws
  /![ \t\f]+/ @excl_ws
  /!/ @excl_no_ws
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /#/
  /\.\.\./
  /\// @slash
  /@[ \t\f\r\n]+/ @at_post_ws
  /@/ @at_no_ws
}

char_lit = /'/ .begin @char_open {
  /'/ @char_close .end
  /\\[tbnr'"\\$]/ @str_escape
  /\\u\h\h\h\h/ @str_unicode
  /[^'\\\r\n]/ @str_text
}

[[peg]]

# Kotlin parser grammar, shaped after KotlinParser.g4.
# Lexer-hidden tokens: @space and @comment. Significant whitespace: @nl.

semi = semi_item @nl*
semis = semi_item+
semi_item = [
  @semi
  @double_semi
  @nl
]
comma_sep = @nl* @comma @nl*
trailing_comma = @nl* @comma

# Interlaced separators. Nest requires these to be named rules.
disj_sep = @nl* @disj @nl*
conj_sep = @nl* @conj @nl*
elvis_sep = @nl* elvis @nl*
range_sep = @nl* range_op @nl*
eq_sep = equality_op @nl*
cmp_sep = comparison_op @nl*
add_sep = additive_operator @nl*
mul_sep = multiplicative_op @nl*

# SECTION: general
main = shebang_line? @nl* file_annotation* package_header import_list top_level_object* @nl*
shebang_line = @shebang_line @nl+
file_annotation = annotation
package_header = package_header_body?
package_header_body = "package" identifier semi?
import_list = import_header*
import_header = "import" identifier import_suffix? semi?
import_suffix = [
  @dot @star
  "as" simple_id
]
top_level_object = declaration semis?

# SECTION: declarations
declaration = [
  class_declaration
  object_declaration
  function_declaration
  property_declaration
  type_alias
]
type_alias = modifier* "typealias" @nl* simple_id nl_type_parameters? @nl* @assign @nl* type

# SECTION: classes
class_declaration = modifier* class_kind @nl* simple_id nl_type_parameters? nl_primary_constructor? nl_delegation_specifiers? nl_type_constraints? nl_class_body?
class_kind = [
  "class"
  "fun" @nl* "interface"
  "interface"
]
nl_type_parameters = @nl* type_parameters
nl_primary_constructor = @nl* primary_constructor
nl_delegation_specifiers = @nl* @colon @nl* delegation_specifiers
nl_type_constraints = @nl* type_constraints
nl_class_body = @nl* class_body_variant
class_body_variant = [
  class_body
  enum_class_body
]
primary_constructor = primary_constructor_head? class_parameters
primary_constructor_head = modifier* "constructor" @nl*
class_body = block
class_parameters = @lparen @nl* class_parameter*<comma_sep> trailing_comma? @nl* @rparen
class_parameter = modifier* val_or_var? @nl* simple_id @nl* @colon @nl* type default_value?
val_or_var = [
  "val"
  "var"
]
default_value = @nl* @assign @nl* expression
delegation_specifiers = annotated_delegation_specifier+<comma_sep>
annotated_delegation_specifier = annotation* @nl* delegation_specifier
delegation_specifier = [
  constructor_invocation
  explicit_delegation
  user_type
  function_type
  "suspend" @nl* function_type
]
constructor_invocation = user_type @nl* value_arguments
explicit_delegation = explicit_delegation_lhs @nl* "by" @nl* expression
explicit_delegation_lhs = [
  user_type
  function_type
]

# SECTION: class members
class_member_declarations = class_member_declaration_list?
class_member_declaration_list = class_member_declaration+<semis> semis?
class_member_declaration = [
  declaration
  companion_object
  anonymous_initializer
  secondary_constructor
]
anonymous_initializer = "init" @nl* block
companion_object = modifier* "companion" @nl* data_modifier? @nl* "object" nl_simple_id? nl_delegation_specifiers? nl_class_body?
data_modifier = "data"
nl_simple_id = @nl* simple_id
secondary_constructor = modifier* "constructor" @nl* function_value_parameters nl_constructor_delegation_call? nl_block?
nl_constructor_delegation_call = @nl* @colon @nl* constructor_delegation_call
nl_block = @nl* block
constructor_delegation_call = [
  "this" @nl* value_arguments
  "super" @nl* value_arguments
]

# SECTION: functions and properties
function_value_parameters = @lparen @nl* function_value_parameter*<comma_sep> trailing_comma? @nl* @rparen
function_value_parameter = parameter_modifier* parameter default_value?
parameter = simple_id @nl* @colon @nl* type
parameter_with_optional_type = simple_id @nl* type_annotation?
function_value_parameter_with_optional_type = parameter_modifier* parameter_with_optional_type default_value?
parameters_with_optional_type = @lparen @nl* function_value_parameter_with_optional_type*<comma_sep> trailing_comma? @nl* @rparen

function_declaration = modifier* "fun" nl_type_parameters? nl_receiver_type_dot? @nl* simple_id @nl* function_value_parameters nl_return_type? nl_type_constraints? nl_function_body?
nl_receiver_type_dot = @nl* receiver_type @nl* @dot
nl_return_type = @nl* @colon @nl* type
nl_function_body = @nl* function_body
function_body = [
  block
  @assign @nl* expression
]

property_declaration = modifier* val_or_var nl_type_parameters? nl_receiver_type_dot? nl_property_variable nl_type_constraints? nl_property_initializer? nl_property_accessors?
nl_property_variable = @nl* property_variable
property_variable = [
  multi_variable_declaration
  variable_declaration
]
variable_declaration = annotation* @nl* simple_id type_annotation?
type_annotation = @nl* @colon @nl* type
multi_variable_declaration = @lparen @nl* variable_declaration+<comma_sep> trailing_comma? @nl* @rparen
nl_property_initializer = @nl* property_initializer
property_initializer = [
  @assign @nl* expression
  property_delegate
]
property_delegate = "by" @nl* expression
nl_property_accessors = @nl* property_accessors
property_accessors = [
  getter nl_setter?
  setter nl_getter?
]
nl_getter = @nl* semi? getter
nl_setter = @nl* semi? setter
getter = modifier* "get" getter_body?
getter_body = @nl* @lparen @nl* @rparen nl_return_type? @nl* function_body
setter = modifier* "set" setter_body?
setter_body = @nl* @lparen @nl* function_value_parameter_with_optional_type trailing_comma? @nl* @rparen nl_return_type? @nl* function_body

object_declaration = modifier* "object" @nl* simple_id nl_delegation_specifiers? nl_class_body?

# SECTION: enum classes
enum_class_body = enum_entries enum_members?
enum_entries = enum_entry+<comma_sep> trailing_comma?
enum_entry = modifier* @nl* simple_id enum_entry_args? nl_class_body?
enum_entry_args = @nl* value_arguments
enum_members = @nl* @semi @nl* class_member_declarations

# SECTION: types
type = type_modifier* type_body
type_body = [
  function_type
  parenthesized_type
  definitely_non_nullable_type
  nullable_type
  type_reference
]
type_reference = [
  user_type
  "dynamic"
]
nullable_type = nullable_type_base @nl* quest+
nullable_type_base = [
  type_reference
  parenthesized_type
]
quest = [
  @quest_no_ws
  @quest_ws
]
user_type = simple_user_type+<user_type_dot_sep>
user_type_dot_sep = @nl* @dot @nl*
simple_user_type = simple_id nl_type_arguments?
nl_type_arguments = @nl* type_arguments
type_arguments = @langle @nl* type_projection+<comma_sep> trailing_comma? @nl* @rangle
type_projection = [
  type_projection_modifier* type
  @star
]
type_projection_modifier = [
  variance_modifier @nl*
  annotation
]
function_type = receiver_type_prefix? function_type_parameters @nl* @arrow @nl* type
receiver_type_prefix = receiver_type @nl* @dot @nl*
function_type_parameters = @lparen @nl* function_type_parameter*<comma_sep> trailing_comma? @nl* @rparen
function_type_parameter = [
  parameter
  type
]
parenthesized_type = @lparen @nl* type @nl* @rparen
receiver_type = type_modifier* receiver_type_body
receiver_type_body = [
  parenthesized_type
  nullable_type
  type_reference
]
definitely_non_nullable_type = definitely_non_nullable_lhs @nl* @amp @nl* type_modifier* definitely_non_nullable_rhs
definitely_non_nullable_lhs = [
  user_type
  parenthesized_user_type
]
definitely_non_nullable_rhs = [
  user_type
  parenthesized_user_type
]
parenthesized_user_type = @lparen @nl* parenthesized_user_type_body @nl* @rparen
parenthesized_user_type_body = [
  user_type
  parenthesized_user_type
]
type_modifier = [
  annotation
  "suspend" @nl*
]
type_parameters = @langle @nl* type_parameter+<comma_sep> trailing_comma? @nl* @rangle
type_parameter = type_parameter_modifier* @nl* simple_id type_bound?
type_bound = @nl* @colon @nl* type
type_constraints = "where" @nl* type_constraint+<comma_sep>
type_constraint = annotation* simple_id @nl* @colon @nl* type
variance_modifier = [
  "in"
  "out"
]
type_parameter_modifier = [
  "reified"
  variance_modifier
  annotation
]

# SECTION: statements
statements = statement_list? semis?
statement_list = statement+<semis>
statement = statement_prefix* statement_body
statement_prefix = [
  label
  annotation
]
statement_body = [
  declaration
  assignment
  loop_statement
  expression
]
control_structure_body = [
  block
  statement
]
block = @lbrace @nl* statements @nl* @rbrace
loop_statement = [
  for_statement
  while_statement
  do_while_statement
]
for_statement = "for" @nl* @lparen annotation* for_variable "in" expression @rparen @nl* control_structure_body?
for_variable = [
  variable_declaration
  multi_variable_declaration
]
while_statement = "while" @nl* @lparen expression @rparen @nl* while_body
while_body = [
  control_structure_body
  @semi
]
do_while_statement = "do" @nl* control_structure_body? @nl* "while" @nl* @lparen expression @rparen
assignment = [
  directly_assignable_expression @assign @nl* expression
  assignable_expression assignment_and_operator @nl* expression
]
assignment_and_operator = [
  @plus_assign
  @minus_assign
  @star_assign
  @slash_assign
  @mod_assign
]

# SECTION: expressions
expression = disjunction
disjunction = conjunction+<disj_sep>
conjunction = equality+<conj_sep>
equality = comparison+<eq_sep>
equality_op = [
  @eqeqeq
  @eqeq
  @noteqeq
  @noteq
]
comparison = generic_call_like_comparison+<cmp_sep>
comparison_op = [
  @le
  @ge
  @langle
  @rangle
]
generic_call_like_comparison = infix_operation call_suffix*
infix_operation = elvis_expression infix_operation_tail*
infix_operation_tail = [
  in_operator @nl* elvis_expression
  is_operator @nl* type
]
in_operator = [
  "in"
  @not_in
]
is_operator = [
  "is"
  @not_is
]
elvis_expression = infix_function_call+<elvis_sep>
elvis = @elvis
infix_function_call = range_expression infix_function_call_tail*
infix_function_call_tail = simple_id @nl* range_expression
range_expression = additive_expression+<range_sep>
range_op = [
  @range
  @range_until
]
additive_expression = multiplicative_expression+<add_sep>
additive_operator = [
  @plus
  @minus
]
multiplicative_expression = as_expression+<mul_sep>
multiplicative_op = [
  @star
  @slash
  @mod
]
as_expression = prefix_unary_expression as_expression_tail*
as_expression_tail = @nl* as_operator @nl* type
as_operator = [
  @as_safe
  "as"
]
prefix_unary_expression = unary_prefix* postfix_unary_expression
unary_prefix = [
  annotation
  label
  prefix_unary_operator @nl*
]
prefix_unary_operator = [
  @incr
  @decr
  @minus
  @plus
  excl
]
excl = [
  @excl_no_ws
  @excl_ws
]
postfix_unary_expression = primary_expression postfix_unary_suffix*
postfix_unary_suffix = [
  postfix_unary_operator
  type_arguments
  call_suffix
  indexing_suffix
  navigation_suffix
]
postfix_unary_operator = [
  @incr
  @decr
  @excl_no_ws excl
]
directly_assignable_expression = [
  postfix_unary_expression assignable_suffix
  simple_id
  parenthesized_directly_assignable_expression
]
parenthesized_directly_assignable_expression = @lparen @nl* directly_assignable_expression @nl* @rparen
assignable_expression = [
  prefix_unary_expression
  parenthesized_assignable_expression
]
parenthesized_assignable_expression = @lparen @nl* assignable_expression @nl* @rparen
assignable_suffix = [
  type_arguments
  indexing_suffix
  navigation_suffix
]
indexing_suffix = @lbracket @nl* expression+<comma_sep> trailing_comma? @nl* @rbracket
navigation_suffix = member_access_operator @nl* navigation_target
member_access_operator = [
  @safe_dot
  @dot
  @coloncolon
]
navigation_target = [
  simple_id
  parenthesized_expression
  "class"
]
call_suffix = [
  type_arguments? value_arguments? annotated_lambda : lambda_call
  type_arguments? value_arguments : value_call
]
annotated_lambda = annotation* label? @nl* lambda_literal
value_arguments = @lparen @nl* value_argument*<comma_sep> trailing_comma? @nl* @rparen
value_argument = annotation? @nl* named_argument? @star? @nl* expression
named_argument = simple_id @nl* @assign @nl*

# SECTION: primary expressions
primary_expression = [
  parenthesized_expression
  simple_id
  literal_constant
  string_literal
  callable_reference
  function_literal
  object_literal
  collection_literal
  this_expression
  super_expression
  if_expression
  when_expression
  try_expression
  jump_expression
]
parenthesized_expression = @lparen @nl* expression @nl* @rparen
collection_literal = @lbracket @nl* collection_elements? @nl* @rbracket
collection_elements = expression+<comma_sep> trailing_comma?
literal_constant = [
  "true"
  "false"
  @int_lit
  @hex_lit
  @bin_lit
  char_lit
  @float_lit
  "null"
  @long_lit
  @unsigned_lit
]
char_lit = @char_open char_content* @char_close
char_content = [
  @str_escape
  @str_unicode
  @str_text
]
string_literal = [
  line_string_literal
  multi_line_string_literal
]
line_string_literal = str
str = @str_open line_string_element* @str_close
line_string_element = [
  line_string_content
  line_string_expression
]
line_string_content = [
  @str_text
  @str_escape
  @str_unicode
  @str_ref
]
line_string_expression = str_interp
str_interp = @str_expr_open @nl* expression @nl* @str_expr_close
multi_line_string_literal = multiline_str
multiline_str = @ml_str_open multi_line_string_element* @ml_str_close
multi_line_string_element = [
  multi_line_string_content
  multi_line_string_expression
]
multi_line_string_content = [
  @str_text
  @str_ref
]
multi_line_string_expression = ml_str_interp
ml_str_interp = @str_expr_open @nl* expression @nl* @str_expr_close
lambda_literal = block
anonymous_function = "suspend"? @nl* "fun" anonymous_function_receiver? @nl* parameters_with_optional_type nl_return_type? nl_type_constraints? nl_function_body?
anonymous_function_receiver = @nl* type @nl* @dot
function_literal = [
  lambda_literal
  anonymous_function
]
object_literal = "object" object_literal_delegation? nl_class_body?
object_literal_delegation = @nl* @colon @nl* delegation_specifiers @nl*
this_expression = [
  @this_at
  "this"
]
super_expression = [
  @super_at
  "super" type_arguments?
]
if_expression = "if" @nl* @lparen @nl* expression @nl* @rparen @nl* if_body
if_body = [
  control_structure_body nl_else?
  @semi
]
nl_else = @nl* else_branch
else_branch = "else" @nl* else_body
else_body = [
  control_structure_body
  @semi
]
when_subject = @lparen when_subject_variable? expression @rparen
when_subject_variable = annotation* @nl* "val" @nl* variable_declaration @nl* @assign @nl*
when_expression = "when" @nl* when_subject? @nl* block
try_expression = "try" @nl* block try_tail
try_tail = [
  catch_block_with_nl+ nl_finally_block?
  nl_finally_block
]
catch_block_with_nl = @nl* catch_block
nl_finally_block = @nl* finally_block
catch_block = "catch" @nl* @lparen annotation* simple_id @colon type trailing_comma? @rparen @nl* block
finally_block = "finally" @nl* block
jump_expression = [
  "throw" @nl* expression
  @return_at expression?
  "return" expression?
  @continue_at
  "continue"
  @break_at
  "break"
]
callable_reference = receiver_type? @coloncolon @nl* callable_reference_target
callable_reference_target = [
  simple_id
  "class"
]

# SECTION: annotations and labels
annotation = [
  single_annotation
  multi_annotation
]
single_annotation = annotation_prefix unescaped_annotation @nl*
multi_annotation = annotation_prefix @lbracket unescaped_annotation+ @rbracket @nl*
annotation_prefix = [
  annotation_use_site @nl*
  at
]
annotation_use_site = at annotation_target @nl* @colon
at = [
  @at_no_ws
  @at_post_ws
]
annotation_target = [
  "field"
  "property"
  "get"
  "set"
  "receiver"
  "param"
  "setparam"
  "delegate"
  "file"
]
unescaped_annotation = [
  user_type @nl* value_arguments : with_args
  user_type : type_only
]
label = @label_ref @nl*

# SECTION: modifiers
modifier = [
  class_modifier @nl*
  member_modifier @nl*
  visibility_modifier @nl*
  function_modifier @nl*
  property_modifier @nl*
  inheritance_modifier @nl*
  parameter_modifier @nl*
  platform_modifier @nl*
  annotation
]
class_modifier = [
  "enum"
  "sealed"
  "annotation"
  "data"
  "inner"
]
member_modifier = [
  "override"
  "lateinit"
]
visibility_modifier = [
  "public"
  "private"
  "internal"
  "protected"
]
function_modifier = [
  "tailrec"
  "operator"
  "infix"
  "inline"
  "external"
  "suspend"
]
property_modifier = "const"
inheritance_modifier = [
  "abstract"
  "final"
  "open"
]
parameter_modifier = [
  "vararg"
  "noinline"
  "crossinline"
]
platform_modifier = [
  "expect"
  "actual"
]

# SECTION: identifiers
simple_id = [
  !hard_keyword @ident
  soft_keyword
]
hard_keyword = [
  "as"
  "break"
  "class"
  "continue"
  "do"
  "else"
  "for"
  "fun"
  "if"
  "in"
  "interface"
  "is"
  "null"
  "object"
  "package"
  "return"
  "super"
  "this"
  "throw"
  "try"
  "typealias"
  "typeof"
  "val"
  "var"
  "when"
  "while"
  "true"
  "false"
]
soft_keyword = [
  "abstract"
  "annotation"
  "by"
  "catch"
  "companion"
  "constructor"
  "crossinline"
  "data"
  "dynamic"
  "enum"
  "external"
  "final"
  "finally"
  "get"
  "import"
  "infix"
  "init"
  "inline"
  "inner"
  "internal"
  "lateinit"
  "noinline"
  "open"
  "operator"
  "out"
  "override"
  "private"
  "protected"
  "public"
  "reified"
  "sealed"
  "tailrec"
  "set"
  "vararg"
  "where"
  "field"
  "property"
  "receiver"
  "param"
  "setparam"
  "delegate"
  "file"
  "expect"
  "actual"
  "const"
  "suspend"
]
identifier = simple_id+<user_type_dot_sep>
