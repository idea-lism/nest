# Kotlin lexer/scoped-token proof grammar in nest syntax.
# The VPA mirrors KotlinLexer.g4 modes as TokenTree scopes.  The PEG is still
# deliberately shallow: each lexical scope has its own private list/item/token
# grammar so rule closures cannot leak across scopes while the real Kotlin PEG is
# rebuilt scope-by-scope.

[[vpa]]
%ignore @delimited_comment @line_comment @ws @inside_nl

*hidden = {
  delimited_comment
  /\/\/[^\r\n]*/ @line_comment
  /[ \t\f]+/ @ws
}

*layout_sensitive_ops = {
  /([ \t\f]|\r?\n)+@([ \t\f]|\r?\n)+/ @at_both_ws
  /([ \t\f]|\r?\n)+@/ @at_pre_ws
  /@([ \t\f]|\r?\n)+/ @at_post_ws
  /\?([ \t\f]|\r?\n)+/ @quest_ws
  /!in([ \t\f]|\r?\n)+/ @not_in
  /!is([ \t\f]|\r?\n)+/ @not_is
  /!([ \t\f]|\r?\n)+/ @excl_ws
}

*separators_and_operations = {
  *layout_sensitive_ops
  /\.\.\./ @reserved
  /\.\.</ @range_until
  /\.\./ @range
  /\./ @dot
  /,/ @comma
  /\+\+/ @incr
  /--/ @decr
  /&&/ @conj
  /\|\|/ @disj
  /!==/ @excl_eqeq
  /!=/ @excl_eq
  /!/ @excl_no_ws
  /::/ @coloncolon
  /:/ @colon
  /;;/ @double_semicolon
  /;/ @semicolon
  /\+=/ @add_assignment
  /-=/ @sub_assignment
  /\*=/ @mult_assignment
  /\/=/ @div_assignment
  /%=/ @mod_assignment
  /=>/ @double_arrow
  /->/ @arrow
  /===/ @eqeqeq
  /==/ @eqeq
  /=/ @assignment
  /<=/ @le
  />=/ @ge
  /</ @langle
  />/ @rangle
  /as\?/ @as_safe
  /\?/ @quest_no_ws
  /#/ @hash
  /@/ @at_no_ws
  /\*/ @mult
  /%/ @mod
  /\// @div
  /\+/ @add
  /-/ @sub
  /'/ @single_quote
  /&/ @amp
}

*keywords = {
  /return@[A-Za-z_][A-Za-z_0-9]*/ @return_at
  /continue@[A-Za-z_][A-Za-z_0-9]*/ @continue_at
  /break@[A-Za-z_][A-Za-z_0-9]*/ @break_at
  /this@[A-Za-z_][A-Za-z_0-9]*/ @this_at
  /super@[A-Za-z_][A-Za-z_0-9]*/ @super_at
  "typealias" @type_alias
  "constructor" @constructor
  "companion" @companion
  "crossinline" @crossinline
  "annotation" @annotation
  "protected" @protected
  "continue" @continue
  "internal" @internal
  "operator" @operator
  "override" @override
  "lateinit" @lateinit
  "noinline" @noinline
  "property" @property
  "setparam" @setparam
  "package" @package
  "interface" @interface
  "dynamic" @dynamic
  "private" @private
  "tailrec" @tailrec
  "external" @external
  "suspend" @suspend
  "reified" @reified
  "receiver" @receiver
  "delegate" @delegate
  "import" @import
  "object" @object
  "typeof" @typeof
  "where" @where
  "catch" @catch
  "finally" @finally
  "while" @while
  "throw" @throw
  "return" @return
  "break" @break
  "public" @public
  "sealed" @sealed
  "abstract" @abstract
  "actual" @actual
  "class" @class
  "init" @init
  "this" @this
  "super" @super
  "when" @when
  "else" @else
  "true" @boolean_literal
  "false" @boolean_literal
  "null" @null_literal
  "enum" @enum
  "data" @data
  "inner" @inner
  "value" @value
  "inline" @inline
  "infix" @infix
  "final" @final
  "open" @open
  "const" @const
  "vararg" @vararg
  "expect" @expect
  "field" @field
  "file" @file
  "param" @param
  "fun" @fun
  "val" @val
  "var" @var
  "try" @try
  "for" @for
  "do" @do
  "as" @as
  "is" @is
  "in" @in
  "out" @out
  "get" @get
  "set" @set
  "by" @by
  "if" @if
}

*inside_keywords = {
  /return@[A-Za-z_][A-Za-z_0-9]*/ @return_at
  /continue@[A-Za-z_][A-Za-z_0-9]*/ @continue_at
  /break@[A-Za-z_][A-Za-z_0-9]*/ @break_at
  "continue" @continue
  "protected" @protected
  "internal" @internal
  "operator" @operator
  "override" @override
  "lateinit" @lateinit
  "noinline" @noinline
  "property" @property
  "setparam" @setparam
  "crossinline" @crossinline
  "annotation" @annotation
  "abstract" @abstract
  "private" @private
  "tailrec" @tailrec
  "external" @external
  "suspend" @suspend
  "reified" @reified
  "receiver" @receiver
  "delegate" @delegate
  "object" @object
  "super" @super
  "when" @when
  "throw" @throw
  "return" @return
  "break" @break
  "public" @public
  "sealed" @sealed
  "actual" @actual
  "else" @else
  "true" @boolean_literal
  "false" @boolean_literal
  "null" @null_literal
  "enum" @enum
  "data" @data
  "inner" @inner
  "value" @value
  "inline" @inline
  "infix" @infix
  "final" @final
  "open" @open
  "const" @const
  "vararg" @vararg
  "expect" @expect
  "field" @field
  "file" @file
  "param" @param
  "fun" @fun
  "val" @val
  "var" @var
  "try" @try
  "for" @for
  "do" @do
  "as" @as
  "is" @is
  "in" @in
  "out" @out
  "get" @get
  "set" @set
  "if" @if
}

*literals_and_identifiers = {
  /0[xX][0-9a-fA-F][0-9a-fA-F_]*[uU][lL]?/ @unsigned_literal
  /0[bB][01][01_]*[uU][lL]?/ @unsigned_literal
  /[1-9][0-9_]*[0-9][uU][lL]?/ @unsigned_literal
  /[0-9][uU][lL]?/ @unsigned_literal
  /0[xX][0-9a-fA-F][0-9a-fA-F_]*[lL]/ @long_literal
  /0[bB][01][01_]*[lL]/ @long_literal
  /[1-9][0-9_]*[0-9][lL]/ @long_literal
  /[0-9][lL]/ @long_literal
  /([0-9][0-9_]*)?\.[0-9][0-9_]*([eE][+\-]?[0-9][0-9_]*)?[fF]?/ @real_literal
  /[0-9][0-9_]*[eE][+\-]?[0-9][0-9_]*[fF]?/ @real_literal
  /[0-9][0-9_]*[fF]/ @real_literal
  /0[xX][0-9a-fA-F][0-9a-fA-F_]*/ @hex_literal
  /0[bB][01][01_]*/ @bin_literal
  /[1-9][0-9_]*[0-9]/ @integer_literal
  /[0-9]/ @integer_literal
  /'(\\u[0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F]|\\[tbrn'"\\$]|[^\n\r'\\])'/ @character_literal
  /[A-Za-z_][A-Za-z_0-9]*/ @identifier
  /`[^`\r\n]+`/ @identifier
}

*default_units = {
  /#![^\r\n]*/ @shebang_line
  line_string
  multiline_string
  delimited_comment
  /\/\/[^\r\n]*/ @line_comment
  parens
  brackets
  block
  *keywords
  *literals_and_identifiers
  *separators_and_operations
  /\r\n?/ @nl
  /\n/ @nl
  /[ \t\f]+/ @ws
}

*inside_units = {
  line_string
  multiline_string
  delimited_comment
  /\/\/[^\r\n]*/ @line_comment
  parens
  brackets
  block
  *inside_keywords
  *literals_and_identifiers
  *separators_and_operations
  /\r\n?/ @inside_nl
  /\n/ @inside_nl
  /[ \t\f]+/ @ws
}

main = {
  *default_units
  EOF .end
}

delimited_comment = /\/\*/ .begin @delimited_comment {
  delimited_comment
  /\*\// .end
  /[^*\/]+/
  /\*/
  /\//
}

block = /[{]/ .begin @lcurl {
  *default_units
  /[}]/ @rcurl .end
}

parens = /\(/ .begin @lparen {
  *inside_units
  /\)/ @rparen .end
}

brackets = /\[/ .begin @lsquare {
  *inside_units
  /\]/ @rsquare .end
}

line_string = /"/ .begin @quote_open {
  /"/ @quote_close .end
  line_str_expr
  /\$[A-Za-z_][A-Za-z_0-9]*/ @line_str_ref
  /\\u[0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F]/ @line_str_escaped_char
  /\\[tbrn'"\\$]/ @line_str_escaped_char
  /[^"\\$]+/ @line_str_text
  /\$/ @line_str_text
}

line_str_expr = /\$[{]/ .begin @line_str_expr_start {
  *default_units
  /[}]/ @rcurl .end
}

multiline_string = /"""/ .begin @triple_quote_open {
  /"{3,}/ @triple_quote_close .end
  multi_line_str_expr
  /\$[A-Za-z_][A-Za-z_0-9]*/ @multi_line_str_ref
  /"{1,2}/ @multi_line_str_text
  /[^"$]+/ @multi_line_str_text
  /\$/ @multi_line_str_text
}

multi_line_str_expr = /\$[{]/ .begin @multi_line_str_expr_start {
  *default_units
  /[}]/ @rcurl .end
}

[[peg]]

main = file
file = [
  shebang_file : shebang
  file_rest : no_shebang
]
shebang_file = shebang_line file_rest
file_rest = nl_star file_annotation* package_decl? import_decl* top_decl* nl_star
shebang_line = @shebang_line nl nl_star
nl = @nl
nl_star = nl*
semi = [
  @semicolon nl_star : semicolon
  @nl nl_star : newline
]

file_annotation = annotation_site @file op_colon annotation_payload nl_star
annotation_site = [
  @at_no_ws : at_no_ws
  @at_pre_ws : at_pre_ws
]
annotation_payload = [
  brackets : brackets
  annotation : annotation
]

package_decl = @package qualified_name semi?
import_decl = @import qualified_name import_suffix? semi?
import_suffix = [
  op_dot op_mult : all
  @as simple_id : alias
]
qualified_name = simple_id+<op_dot>

top_decl = [
  declaration : declaration
  statement : statement
  nl : nl
]
declaration = [
  class_decl : class_decl
  fun_decl : fun_decl
  prop_decl : prop_decl
  type_alias_decl : type_alias_decl
]

class_decl = modifiers? class_kind simple_id type_params? value_params? delegation? type_constraints? class_body?
class_kind = [
  @class : class_kw
  @interface : interface_kw
]
class_body = block
delegation = op_colon expr
type_alias_decl = modifiers? @type_alias simple_id type_params? op_assignment type_ref

fun_decl = modifiers? @fun type_params? simple_id value_params type_constraints? fun_body?
value_params = parens
fun_body = [
  op_assignment expr : expr_body
  block : block_body
]

prop_decl = modifiers? val_var simple_id type_ann? prop_init?
val_var = [
  @val : val_kw
  @var : var_kw
]
prop_init = op_assignment expr
type_ann = op_colon type_ref
type_constraints = @where type_constraint*<op_comma>
type_constraint = simple_id op_colon type_ref
type_params = op_langle type_param*<op_comma> op_comma? op_rangle
type_param = modifiers? simple_id type_ann?
type_ref = type_atom+
type_atom = [
  simple_id : simple_id
  parens : parens
  brackets : brackets
  type_op : type_op
]
type_op = [
  op_dot : dot
  op_quest_no_ws : nullable
  op_quest_ws : nullable_ws
  op_langle : langle
  op_rangle : rangle
  op_comma : comma
  op_mult : mult
  @in : in_kw
  @out : out_kw
]

block = @lcurl block_content @rcurl
block_content = [
  lambda_content : lambda
  statement_content : statements
]
lambda_content = lambda_header statement_content?
lambda_header = lambda_param*<op_comma> op_arrow
lambda_param = simple_id type_ann?
statement_content = block_item*
block_item = [
  nl : nl
  shebang_line : shebang
  statement : statement
]
statement = [
  declaration : declaration
  assignment : assignment
  loop_stmt : loop_stmt
  expr : expr
]
assignment = assignable assign_op expr
assignable = [
  simple_id : id
  parens : parens
  brackets : brackets
]
assign_op = [
  op_assignment : assign
  op_add_assignment : add_assign
  op_sub_assignment : sub_assign
  op_mult_assignment : mult_assign
  op_div_assignment : div_assign
  op_mod_assignment : mod_assign
]
loop_stmt = [
  @for parens control_body? : for_stmt
  @while parens while_body : while_stmt
  @do control_body? @while parens : do_while_stmt
]
while_body = [
  control_body : body
  op_semicolon : semi
]
control_body = [
  block : block
  statement : statement
]

expr = prefix* postfix_expr expr_tail*
expr_tail = nl_star operator nl_star prefix* postfix_expr
postfix_expr = primary_expr postfix_part*
postfix_part = [
  parens : call
  brackets : index
]
primary_expr = [
  literal : literal
  simple_id : simple_id
  keyword_atom : keyword
  block : block
  parens : parens
  brackets : brackets
  line_string : line_string
  multiline_string : multiline_string
]
prefix = [
  operator : operator
  modifier_kw : modifier
]

parens = @lparen parens_body? @rparen
parens_body = parens_item*<iop_comma> iop_comma?
parens_item = inside_expr
brackets = @lsquare brackets_body? @rsquare
brackets_body = inside_expr*<iop_comma> iop_comma?
inside_expr = inside_prefix* inside_postfix_expr inside_expr_tail*
inside_expr_tail = i_operator inside_prefix* inside_postfix_expr
inside_postfix_expr = inside_primary_expr inside_postfix_part*
inside_postfix_part = [
  parens : call
  brackets : index
]
inside_primary_expr = [
  i_literal : literal
  i_simple_id : simple_id
  i_keyword_atom : keyword
  block : block
  parens : parens
  brackets : brackets
  line_string : line_string
  multiline_string : multiline_string
]
inside_prefix = [
  i_operator : operator
  i_modifier_kw : modifier
]

line_string = @quote_open line_part* @quote_close
line_part = [
  line_str_expr : expr
  @line_str_ref : ref
  @line_str_text : text
  @line_str_escaped_char : escaped
]
line_str_expr = @line_str_expr_start block_item* @rcurl
multiline_string = @triple_quote_open multiline_part* @triple_quote_close
multiline_part = [
  multi_line_str_expr : expr
  @multi_line_str_ref : ref
  @multi_line_str_text : text
]
multi_line_str_expr = @multi_line_str_expr_start block_item* @rcurl

modifiers = modifier+
modifier = [
  annotation : annotation
  modifier_kw : modifier_kw
]
annotation = annotation_site? simple_id annotation_args?
annotation_args = [
  parens : parens
  brackets : brackets
]

op_reserved = @reserved
op_dot = @dot
op_comma = @comma
op_mult = @mult
op_mod = @mod
op_div = @div
op_add = @add
op_sub = @sub
op_incr = @incr
op_decr = @decr
op_conj = @conj
op_disj = @disj
op_excl_ws = @excl_ws
op_excl_no_ws = @excl_no_ws
op_colon = @colon
op_semicolon = @semicolon
op_assignment = @assignment
op_add_assignment = @add_assignment
op_sub_assignment = @sub_assignment
op_mult_assignment = @mult_assignment
op_div_assignment = @div_assignment
op_mod_assignment = @mod_assignment
op_arrow = @arrow
op_double_arrow = @double_arrow
op_range = @range
op_range_until = @range_until
op_coloncolon = @coloncolon
op_double_semicolon = @double_semicolon
op_hash = @hash
op_at_no_ws = @at_no_ws
op_at_post_ws = @at_post_ws
op_at_pre_ws = @at_pre_ws
op_at_both_ws = @at_both_ws
op_quest_ws = @quest_ws
op_quest_no_ws = @quest_no_ws
op_langle = @langle
op_rangle = @rangle
op_le = @le
op_ge = @ge
op_excl_eq = @excl_eq
op_excl_eqeq = @excl_eqeq
op_as_safe = @as_safe
op_eqeq = @eqeq
op_eqeqeq = @eqeqeq
op_single_quote = @single_quote
op_amp = @amp
op_not_is = @not_is
op_not_in = @not_in

iop_reserved = @reserved
iop_dot = @dot
iop_comma = @comma
iop_mult = @mult
iop_mod = @mod
iop_div = @div
iop_add = @add
iop_sub = @sub
iop_incr = @incr
iop_decr = @decr
iop_conj = @conj
iop_disj = @disj
iop_excl_ws = @excl_ws
iop_excl_no_ws = @excl_no_ws
iop_colon = @colon
iop_semicolon = @semicolon
iop_assignment = @assignment
iop_add_assignment = @add_assignment
iop_sub_assignment = @sub_assignment
iop_mult_assignment = @mult_assignment
iop_div_assignment = @div_assignment
iop_mod_assignment = @mod_assignment
iop_arrow = @arrow
iop_double_arrow = @double_arrow
iop_range = @range
iop_range_until = @range_until
iop_coloncolon = @coloncolon
iop_double_semicolon = @double_semicolon
iop_hash = @hash
iop_at_no_ws = @at_no_ws
iop_at_post_ws = @at_post_ws
iop_at_pre_ws = @at_pre_ws
iop_at_both_ws = @at_both_ws
iop_quest_ws = @quest_ws
iop_quest_no_ws = @quest_no_ws
iop_langle = @langle
iop_rangle = @rangle
iop_le = @le
iop_ge = @ge
iop_excl_eq = @excl_eq
iop_excl_eqeq = @excl_eqeq
iop_as_safe = @as_safe
iop_eqeq = @eqeq
iop_eqeqeq = @eqeqeq
iop_single_quote = @single_quote
iop_amp = @amp
iop_not_is = @not_is
iop_not_in = @not_in

simple_id = [
  @identifier : id_identifier
  @abstract : id_abstract
  @annotation : id_annotation
  @by : id_by
  @catch : id_catch
  @companion : id_companion
  @constructor : id_constructor
  @crossinline : id_crossinline
  @data : id_data
  @dynamic : id_dynamic
  @enum : id_enum
  @external : id_external
  @final : id_final
  @finally : id_finally
  @import : id_import
  @infix : id_infix
  @init : id_init
  @inline : id_inline
  @inner : id_inner
  @internal : id_internal
  @lateinit : id_lateinit
  @noinline : id_noinline
  @open : id_open
  @operator : id_operator
  @out : id_out
  @override : id_override
  @private : id_private
  @protected : id_protected
  @public : id_public
  @reified : id_reified
  @sealed : id_sealed
  @tailrec : id_tailrec
  @vararg : id_vararg
  @where : id_where
  @get : id_get
  @set : id_set
  @field : id_field
  @property : id_property
  @receiver : id_receiver
  @param : id_param
  @setparam : id_setparam
  @delegate : id_delegate
  @file : id_file
  @expect : id_expect
  @actual : id_actual
  @value : id_value
  @const : id_const
  @suspend : id_suspend
]

literal = [
  @boolean_literal : lit_boolean_literal
  @null_literal : lit_null_literal
  @real_literal : lit_real_literal
  @integer_literal : lit_integer_literal
  @hex_literal : lit_hex_literal
  @bin_literal : lit_bin_literal
  @character_literal : lit_character_literal
  @long_literal : lit_long_literal
  @unsigned_literal : lit_unsigned_literal
]

modifier_kw = [
  @public : mod_public
  @private : mod_private
  @protected : mod_protected
  @internal : mod_internal
  @enum : mod_enum
  @sealed : mod_sealed
  @annotation : mod_annotation
  @data : mod_data
  @inner : mod_inner
  @value : mod_value
  @tailrec : mod_tailrec
  @operator : mod_operator
  @inline : mod_inline
  @infix : mod_infix
  @external : mod_external
  @suspend : mod_suspend
  @override : mod_override
  @abstract : mod_abstract
  @final : mod_final
  @open : mod_open
  @const : mod_const
  @lateinit : mod_lateinit
  @vararg : mod_vararg
  @noinline : mod_noinline
  @crossinline : mod_crossinline
  @reified : mod_reified
  @expect : mod_expect
  @actual : mod_actual
]

keyword_atom = [
  @return_at : kw_return_at
  @continue_at : kw_continue_at
  @break_at : kw_break_at
  @this_at : kw_this_at
  @super_at : kw_super_at
  @file : kw_file
  @field : kw_field
  @property : kw_property
  @get : kw_get
  @set : kw_set
  @receiver : kw_receiver
  @param : kw_param
  @setparam : kw_setparam
  @delegate : kw_delegate
  @package : kw_package
  @import : kw_import
  @class : kw_class
  @interface : kw_interface
  @fun : kw_fun
  @object : kw_object
  @val : kw_val
  @var : kw_var
  @type_alias : kw_typealias
  @constructor : kw_constructor
  @by : kw_by
  @companion : kw_companion
  @init : kw_init
  @this : kw_this
  @super : kw_super
  @typeof : kw_typeof
  @where : kw_where
  @if : kw_if
  @else : kw_else
  @when : kw_when
  @try : kw_try
  @catch : kw_catch
  @finally : kw_finally
  @for : kw_for
  @do : kw_do
  @while : kw_while
  @throw : kw_throw
  @return : kw_return
  @continue : kw_continue
  @break : kw_break
  @as : kw_as
  @is : kw_is
  @in : kw_in
  @out : kw_out
  @dynamic : kw_dynamic
]

operator = [
  op_reserved : op_p_reserved
  op_dot : op_p_dot
  op_comma : op_p_comma
  op_mult : op_p_mult
  op_mod : op_p_mod
  op_div : op_p_div
  op_add : op_p_add
  op_sub : op_p_sub
  op_incr : op_p_incr
  op_decr : op_p_decr
  op_conj : op_p_conj
  op_disj : op_p_disj
