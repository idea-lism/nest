# Kotlin grammar in nest syntax
# Based on the official Kotlin grammar specification
# https://kotlinlang.org/grammar/

[[vpa]]
%ignore @space @comment

# Keywords (order matters for VPA: longer matches first by the DFA)
*keywords = @{
  "package"
  "import"
  "class"
  "interface"
  "fun"
  "object"
  "val"
  "var"
  "typealias"
  "constructor"
  "by"
  "companion"
  "init"
  "this"
  "super"
  "typeof"
  "where"
  "if"
  "else"
  "when"
  "try"
  "catch"
  "finally"
  "for"
  "do"
  "while"
  "throw"
  "return"
  "continue"
  "break"
  "as"
  "is"
  "in"
  "out"
  "dynamic"
  "public"
  "private"
  "protected"
  "internal"
  "enum"
  "sealed"
  "annotation"
  "data"
  "inner"
  "tailrec"
  "operator"
  "infix"
  "inline"
  "external"
  "suspend"
  "override"
  "abstract"
  "final"
  "open"
  "const"
  "lateinit"
  "vararg"
  "noinline"
  "crossinline"
  "reified"
  "expect"
  "actual"
  "true"
  "false"
  "null"
  "get"
  "set"
  "field"
  "property"
  "receiver"
  "param"
  "setparam"
  "delegate"
  "file"
}

main = {
  *keywords
  /\/\*([^*]|\*+[^*\/])*\*+\// @comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t]+/ @space
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /\|\|/ @disj
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /,/ @comma
  /:/ @colon
  /;/ @semi
  /\./ @dot
  /\?/ @quest
  /!/ @excl
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /\// @slash
  /@/ @at
}

block = /[{]/ .begin @lbrace {
  *keywords
  /\/\*([^*]|\*+[^*\/])*\*+\// @comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t]+/ @space
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /\|\|/ @disj
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /[}]/ @rbrace .end
  /,/ @comma
  /:/ @colon
  /;/ @semi
  /\./ @dot
  /\?/ @quest
  /!/ @excl
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /\// @slash
  /@/ @at
}

str = /"/ .begin @str_open {
  /"/ @str_close .end
  str_interp
  /\\[tbnr'"\\$]/ @str_escape
  /\\u\h\h\h\h/ @str_unicode
  /\$[A-Za-z_]\w*/ @str_ref
  /[^"\\$\r\n]+/ @str_text
  /\$/ @str_text
}

str_interp = /\$[{]/ .begin @str_expr_open {
  *keywords
  /\/\*([^*]|\*+[^*\/])*\*+\// @comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t]+/ @space
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /\|\|/ @disj
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /[}]/ @str_expr_close .end
  /,/ @comma
  /;/ @semi
  /:/ @colon
  /\./ @dot
  /\?/ @quest
  /!/ @excl
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /\// @slash
  /@/ @at
}

multiline_str = /"""/ .begin @ml_str_open {
  /"{0,2}"""/ @ml_str_close .end
  ml_str_interp
  /\$[A-Za-z_]\w*/ @str_ref
  /"{1,2}/ @str_text
  /[^"$]+/ @str_text
  /\$/ @str_text
}

ml_str_interp = /\$[{]/ .begin @str_expr_open {
  *keywords
  /\/\*([^*]|\*+[^*\/])*\*+\// @comment
  /\/\/[^\r\n]*/ @comment
  str
  multiline_str
  char_lit
  /0[xX]\h+[uU]?[lL]?/ @hex_lit
  /0[bB][01][01_]*[uU]?[lL]?/ @bin_lit
  /(\d[\d_]*)?\.[\d][\d_]*([eE][+\-]?\d[\d_]*)?[fF]?/ @float_lit
  /\d[\d_]*[eE][+\-]?\d[\d_]*[fF]?/ @float_lit
  /\d[\d_]*[fF]/ @float_lit
  /\d[\d_]*[uU]?[lL]/ @long_lit
  /\d[\d_]*[uU]/ @unsigned_lit
  /\d[\d_]*/ @int_lit
  /[A-Za-z_]\w*@/ @label_ref
  /[A-Za-z_]\w*/ @ident
  /`[^`\r\n]+`/ @ident
  /[\r]?\n/ @nl
  /[ \t]+/ @space
  /->/ @arrow
  /::/ @coloncolon
  /===/ @eqeqeq
  /!==/ @noteqeq
  /==/ @eqeq
  /!=/ @noteq
  /<=/ @le
  />=/ @ge
  /&&/ @conj
  /\|\|/ @disj
  /\.\./ @range
  /\+\+/ @incr
  /--/ @decr
  /\+=/ @plus_assign
  /-=/ @minus_assign
  /\*=/ @star_assign
  /\/=/ @slash_assign
  /%=/ @mod_assign
  /\?\./ @safe_dot
  /\?\:/ @elvis
  /as\?/ @as_safe
  /!in\b/ @not_in
  /!is\b/ @not_is
  /\(/ @lparen
  /\)/ @rparen
  /\[/ @lbracket
  /\]/ @rbracket
  block
  /[}]/ @str_expr_close .end
  /,/ @comma
  /;/ @semi
  /:/ @colon
  /\./ @dot
  /\?/ @quest
  /!/ @excl
  /=/ @assign
  /</ @langle
  />/ @rangle
  /\+/ @plus
  /-/ @minus
  /\*/ @star
  /%/ @mod
  /\// @slash
  /@/ @at
}

char_lit = /'/ .begin @char_open {
  /'/ @char_close .end
  /\\[tbnr'"\\$]/ @str_escape
  /\\u\h\h\h\h/ @str_unicode
  /[^'\\\r\n]/ @str_text
}

[[peg]]

# Newline handling: @nl is visible to PEG (not %ignore'd).
# _ eats optional newlines (inside expressions, types, params).
# semi eats statement terminators (one or more newlines/semicolons).
# comma_sep is comma surrounded by optional newlines (for use as separator).
_ = @nl*
semi = semi_item+
semi_item = [
  @semi
  @nl
]
comma_sep = _ @comma _

# Operator separators (sep in +<sep> must be a single rule)
disj_sep = _ @disj _
conj_sep = _ @conj _
elvis_sep = _ @elvis _
range_sep = _ @range _
eq_sep = _ equality_op _
cmp_sep = _ comparison_op _
add_sep = _ additive_op _
mul_sep = _ mult_op _

# Kotlin file structure
main = _ file_part*

file_part = [
  package_header
  import_header
  declaration
]

# Package & import
package_header = "package" identifier semi
import_header = "import" identifier import_suffix? semi
import_suffix = [
  @dot @star
  "as" simple_id
]

# Declarations
declaration = [
  class_decl
  object_decl
  fun_decl
  property_decl
  type_alias
]

type_alias = modifier* "typealias" _ simple_id _ type_params? _ @assign _ type semi?

# Class
class_decl = modifier* class_kw _ simple_id _ type_params? _ primary_constructor? _ delegation? _ type_constraints? _ class_body? semi?
class_kw = [
  "class"
  "interface"
]
primary_constructor = modifier* "constructor"? _ class_params
class_params = @lparen _ class_param*<comma_sep> _ @rparen
class_param = modifier* val_or_var? simple_id _ @colon _ type _ default_value?
val_or_var = [
  "val"
  "var"
]
default_value = @assign _ expression
delegation = @colon _ delegation_spec+<comma_sep>
delegation_spec = [
  user_type _ value_args : ctor_invocation
  user_type _ "by" _ expression : explicit_delegation
  user_type : type_spec
  fun_type : fun_type_spec
]
class_body = _ block
block = @lbrace _ statements _ @rbrace

# Class members (parsed as statements inside class bodies)
companion_obj = modifier* "companion" _ "object" _ simple_id? _ delegation? _ class_body?
secondary_constructor = modifier* "constructor" _ fun_value_params _ delegation_call? _ block?
delegation_call = @colon _ [
  "this" _ value_args
  "super" _ value_args
]
anon_init = "init" _ block

# Functions
fun_decl = modifier* "fun" _ type_params? _ receiver_type_dot? simple_id _ fun_value_params _ return_type? _ type_constraints? _ fun_body? semi?
fun_value_params = @lparen _ fun_value_param*<comma_sep> _ @rparen
fun_value_param = modifier* parameter _ default_value?
parameter = simple_id _ @colon _ type
return_type = @colon _ type
fun_body = [
  block
  @assign _ expression
]
receiver_type_dot = receiver_type @dot _

# Properties
property_decl = modifier* val_or_var _ type_params? _ receiver_type_dot? var_decl _ type_constraints? _ property_init? _ property_accessors? semi?
var_decl = [
  @lparen _ variable_decl+<comma_sep> _ @rparen
  variable_decl
]
variable_decl = simple_id type_annotation?
type_annotation = _ @colon _ type
property_init = [
  @assign _ expression
  "by" _ expression
]
property_accessors = [
  getter _ setter?
  setter _ getter?
]
getter = modifier* "get" _ @lparen _ @rparen _ return_type? _ fun_body
setter = modifier* "set" _ @lparen _ setter_param _ @rparen _ return_type? _ fun_body
setter_param = modifier* simple_id _ type_annotation?

# Object
object_decl = modifier* "object" _ simple_id _ delegation? _ class_body? semi?

# Enum (enum_entry parsed as statement inside enum bodies)
enum_entry = modifier* simple_id _ value_args? _ class_body?

# Types
type = type_modifier* type_inner quest*
type_inner = [
  fun_type
  nullable_type
  paren_type
  type_ref
]
type_ref = [
  user_type
  "dynamic"
]
nullable_type = [
  type_ref quest+
  paren_type quest+
]
quest = [
  @quest
]
user_type = simple_user_type+<@dot>
simple_user_type = simple_id _ type_args?
type_args = @langle _ type_projection+<comma_sep> _ @rangle
type_projection = [
  type_projection_modifier* type
  @star
]
type_projection_modifier = [
  variance_modifier
  annotation
]
fun_type = receiver_type_prefix? fun_type_params _ @arrow _ type
receiver_type_prefix = receiver_type @dot _
fun_type_params = @lparen _ fun_type_param*<comma_sep> _ @rparen
fun_type_param = [
  parameter
  type
]
paren_type = @lparen _ type _ @rparen
receiver_type = type_modifier* receiver_type_inner
receiver_type_inner = [
  nullable_type
  paren_type
  type_ref
]
type_modifier = [
  annotation
  "suspend" _
]

# Type parameters & constraints
type_params = @langle _ type_param+<comma_sep> _ @rangle
type_param = type_param_modifier* simple_id _ type_bound?
type_bound = @colon _ type
type_constraints = "where" _ type_constraint+<comma_sep>
type_constraint = annotation* simple_id _ @colon _ type
variance_modifier = [
  "in"
  "out"
]
type_param_modifier = [
  "reified"
  variance_modifier
  annotation
]

# Statements
statements = _ terminated_stmt*
terminated_stmt = statement semi
statement = [
  declaration
  companion_obj
  secondary_constructor
  anon_init
  enum_entry
  when_entry
  assignment
  loop_stmt
  expression
]
assignment = [
  directly_assignable _ assign_op _ expression
  assignable _ assign_op _ expression
]
assign_op = [
  @assign
  @plus_assign
  @minus_assign
  @star_assign
  @slash_assign
  @mod_assign
]
loop_stmt = [
  for_stmt
  while_stmt
  do_while_stmt
]
for_stmt = "for" _ @lparen _ annotation* for_var _ "in" _ expression _ @rparen _ control_body?
for_var = [
  variable_decl
  @lparen _ variable_decl+<comma_sep> _ @rparen
]
while_stmt = "while" _ @lparen _ expression _ @rparen _ control_body
do_while_stmt = "do" _ control_body? _ "while" _ @lparen _ expression _ @rparen
control_body = [
  block
  statement
]

# Expressions
expression = disjunction
disjunction = conjunction+<disj_sep>
conjunction = equality+<conj_sep>
equality = comparison+<eq_sep>
equality_op = [
  @eqeqeq
  @eqeq
  @noteqeq
  @noteq
]
comparison = generic_call_like+<cmp_sep>
comparison_op = [
  @le
  @ge
  @langle
  @rangle
]
generic_call_like = infix_op _ call_suffix*
infix_op = elvis_expr infix_tail*
infix_tail = [
  _ in_op _ elvis_expr : in_check
  _ is_op _ type : is_check
  _ simple_id _ elvis_expr : named_check
]
in_op = [
  "in"
  @not_in
]
is_op = [
  "is"
  @not_is
]
elvis_expr = infix_fn_call+<elvis_sep>
infix_fn_call = range_expr infix_fn_tail*
infix_fn_tail = _ simple_id _ range_expr
range_expr = additive_expr+<range_sep>
additive_expr = mult_expr+<add_sep>
additive_op = [
  @plus
  @minus
]
mult_expr = as_expr+<mul_sep>
mult_op = [
  @star
  @slash
  @mod
]
as_expr = prefix_unary as_tail*
as_tail = _ as_op _ type
as_op = [
  @as_safe
  "as"
]
prefix_unary = unary_prefix* postfix_unary
unary_prefix = [
  annotation
  label
  prefix_unary_op
]
prefix_unary_op = [
  @incr
  @decr
  @minus
  @plus
  @excl
]
postfix_unary = primary_expr postfix_suffix*
postfix_suffix = [
  @incr
  @decr
  type_args
  call_suffix
  index_suffix
  nav_suffix
]
directly_assignable = [
  postfix_unary assignable_suffix
  simple_id
]
assignable = prefix_unary
assignable_suffix = [
  nav_suffix
  type_args
  index_suffix
]
index_suffix = @lbracket _ expression+<comma_sep> _ @rbracket
nav_suffix = member_access_op _ nav_target
member_access_op = [
  @safe_dot
  @dot
  @coloncolon
]
nav_target = [
  simple_id
  paren_expr
  "class"
]
call_suffix = [
  type_args? _ value_args _ annotated_lambda : args_lambda
  type_args? _ value_args : args_only
  type_args _ annotated_lambda : type_lambda
  _ annotated_lambda : lambda_only
]
annotated_lambda = annotation* label? lambda_lit
value_args = @lparen _ value_arg*<comma_sep> _ @rparen
value_arg = annotation? named_arg? @star? expression
named_arg = simple_id _ @assign _
lambda_lit = block

# Primary expressions
primary_expr = [
  "this" @at simple_id : this_at
  "this" : this_expr
  "super" @at simple_id : super_at
  "super" type_args? : super_expr
  if_expr
  when_expr
  try_expr
  jump_expr
  paren_expr
  callable_ref
  string_lit
  fun_literal
  object_literal
  collection_lit
  simple_id
  literal_const
]
paren_expr = @lparen _ expression _ @rparen
collection_lit = [
  @lbracket _ expression+<comma_sep> _ @rbracket : non_empty
  @lbracket _ @rbracket : empty
]
literal_const = [
  @float_lit
  @hex_lit
  @bin_lit
  @long_lit
  @unsigned_lit
  @int_lit
  "true"
  "false"
  "null"
  char_lit
]
char_lit = @char_open char_content* @char_close
char_content = [
  @str_escape
  @str_unicode
  @str_text
]

# Strings
string_lit = [
  multi_line_str
  line_str
]
line_str = str
str = @str_open line_str_content* @str_close
line_str_content = [
  str_interp
  @str_escape
  @str_unicode
  @str_ref
  @str_text
]
multi_line_str = multiline_str
multiline_str = @ml_str_open ml_str_content* @ml_str_close
ml_str_content = [
  ml_str_interp
  @str_ref
  @str_text
]
str_interp = @str_expr_open _ expression _ @str_expr_close
ml_str_interp = @str_expr_open _ expression _ @str_expr_close

# Function literals & object literals
fun_literal = [
  lambda_lit
  anon_fun
]
anon_fun = "fun" _ receiver_type_dot? fun_value_params _ return_type? _ type_constraints? _ fun_body?
object_literal = [
  "object" _ @colon _ delegation_spec+<comma_sep> _ class_body : with_delegation
  "object" _ class_body : plain
]

# Control flow
if_expr = "if" _ @lparen _ expression _ @rparen _ control_body? _ else_branch?
else_branch = "else" _ control_body
when_expr = "when" _ when_subject? _ block
when_subject = @lparen _ expression _ @rparen
when_entry = [
  when_cond+<comma_sep> _ @arrow _ control_body semi?
  "else" _ @arrow _ control_body semi?
]
when_cond = [
  expression
  in_op _ expression
  is_op _ type
]
try_expr = "try" _ block _ catch_block* _ finally_block?
catch_block = "catch" _ @lparen _ annotation* simple_id _ @colon _ type _ @rparen _ block
finally_block = "finally" _ block
jump_expr = [
  "throw" _ expression : throw_expr
  "return" @at simple_id _ expression? : return_at
  "return" _ expression? : return_expr
  "continue" @at simple_id : continue_at
  "continue" : continue_expr
  "break" @at simple_id : break_at
  "break" : break_expr
]
callable_ref = type? @coloncolon _ callable_ref_target
callable_ref_target = [
  simple_id
  "class"
]

# Annotations & labels
annotation = [
  annotation_use_site unescaped_annotation _
  @at unescaped_annotation _
]
annotation_use_site = @at annotation_target @colon
annotation_target = [
  "field"
  "property"
  "get"
  "set"
  "receiver"
  "param"
  "setparam"
  "delegate"
  "file"
]
unescaped_annotation = [
  user_type _ value_args : with_args
  user_type : type_only
]
label = @label_ref

# Modifiers
modifier = [
  class_modifier _
  member_modifier _
  visibility_modifier _
  function_modifier _
  property_modifier _
  inheritance_modifier _
  parameter_modifier _
  platform_modifier _
  annotation
]
class_modifier = [
  "enum"
  "sealed"
  "annotation"
  "data"
  "inner"
]
member_modifier = [
  "override"
  "lateinit"
]
visibility_modifier = [
  "public"
  "private"
  "internal"
  "protected"
]
function_modifier = [
  "tailrec"
  "operator"
  "infix"
  "inline"
  "external"
  "suspend"
]
property_modifier = "const"
inheritance_modifier = [
  "abstract"
  "final"
  "open"
]
parameter_modifier = [
  "vararg"
  "noinline"
  "crossinline"
]
platform_modifier = [
  "expect"
  "actual"
]

# Identifiers
simple_id = [
  !hard_keyword @ident
  soft_keyword
]
hard_keyword = [
  "as"
  "break"
  "class"
  "continue"
  "do"
  "else"
  "for"
  "fun"
  "if"
  "in"
  "interface"
  "is"
  "null"
  "object"
  "package"
  "return"
  "super"
  "this"
  "throw"
  "try"
  "typealias"
  "typeof"
  "val"
  "var"
  "when"
  "while"
  "true"
  "false"
]
soft_keyword = [
  "abstract"
  "annotation"
  "by"
  "catch"
  "companion"
  "constructor"
  "crossinline"
  "data"
  "dynamic"
  "enum"
  "external"
  "final"
  "finally"
  "get"
  "import"
  "infix"
  "init"
  "inline"
  "inner"
  "internal"
  "lateinit"
  "noinline"
  "open"
  "operator"
  "out"
  "override"
  "private"
  "protected"
  "public"
  "reified"
  "sealed"
  "tailrec"
  "set"
  "vararg"
  "where"
  "field"
  "property"
  "receiver"
  "param"
  "setparam"
  "delegate"
  "file"
  "expect"
  "actual"
  "const"
  "suspend"
]

identifier = simple_id+<@dot>
