# Kotlin lexer/scoped-token proof grammar in nest syntax.
# The VPA mirrors KotlinLexer.g4 modes as TokenTree scopes.  The PEG is still
# deliberately shallow: each lexical scope has its own private list/item/token
# grammar so rule closures cannot leak across scopes while the real Kotlin PEG is
# rebuilt scope-by-scope.

[[vpa]]
%ignore @delimited_comment @line_comment @ws @inside_nl

*hidden = {
  delimited_comment
  /\/\/[^\r\n]*/ @line_comment
  /[ \t\f]+/ @ws
}

*layout_sensitive_ops = {
  /([ \t\f]|\r?\n)+@([ \t\f]|\r?\n)+/ @at_both_ws
  /([ \t\f]|\r?\n)+@/ @at_pre_ws
  /@([ \t\f]|\r?\n)+/ @at_post_ws
  /\?([ \t\f]|\r?\n)+/ @quest_ws
  /!in([ \t\f]|\r?\n)+/ @not_in
  /!is([ \t\f]|\r?\n)+/ @not_is
  /!([ \t\f]|\r?\n)+/ @excl_ws
}

*separators_and_operations = {
  *layout_sensitive_ops
  /\.\.\./ @reserved
  /\.\.</ @range_until
  /\.\./ @range
  /\./ @dot
  /,/ @comma
  /\+\+/ @incr
  /--/ @decr
  /&&/ @conj
  /\|\|/ @disj
  /!==/ @excl_eqeq
  /!=/ @excl_eq
  /!/ @excl_no_ws
  /::/ @coloncolon
  /:/ @colon
  /;;/ @double_semicolon
  /;/ @semicolon
  /\+=/ @add_assignment
  /-=/ @sub_assignment
  /\*=/ @mult_assignment
  /\/=/ @div_assignment
  /%=/ @mod_assignment
  /=>/ @double_arrow
  /->/ @arrow
  /===/ @eqeqeq
  /==/ @eqeq
  /=/ @assignment
  /<=/ @le
  />=/ @ge
  /</ @langle
  />/ @rangle
  /as\?/ @as_safe
  /\?/ @quest_no_ws
  /#/ @hash
  /@/ @at_no_ws
  /\*/ @mult
  /%/ @mod
  /\// @div
  /\+/ @add
  /-/ @sub
  /'/ @single_quote
  /&/ @amp
}

*keywords = {
  /return@[A-Za-z_][A-Za-z_0-9]*/ @return_at
  /continue@[A-Za-z_][A-Za-z_0-9]*/ @continue_at
  /break@[A-Za-z_][A-Za-z_0-9]*/ @break_at
  /this@[A-Za-z_][A-Za-z_0-9]*/ @this_at
  /super@[A-Za-z_][A-Za-z_0-9]*/ @super_at
  "typealias" @type_alias
  "constructor" @constructor
  "companion" @companion
  "crossinline" @crossinline
  "annotation" @annotation
  "protected" @protected
  "continue" @continue
  "internal" @internal
  "operator" @operator
  "override" @override
  "lateinit" @lateinit
  "noinline" @noinline
  "property" @property
  "setparam" @setparam
  "package" @package
  "interface" @interface
  "dynamic" @dynamic
  "private" @private
  "tailrec" @tailrec
  "external" @external
  "suspend" @suspend
  "reified" @reified
  "receiver" @receiver
  "delegate" @delegate
  "import" @import
  "object" @object
  "typeof" @typeof
  "where" @where
  "catch" @catch
  "finally" @finally
  "while" @while
  "throw" @throw
  "return" @return
  "break" @break
  "public" @public
  "sealed" @sealed
  "abstract" @abstract
  "actual" @actual
  "class" @class
  "init" @init
  "this" @this
  "super" @super
  "when" @when
  "else" @else
  "true" @boolean_literal
  "false" @boolean_literal
  "null" @null_literal
  "enum" @enum
  "data" @data
  "inner" @inner
  "value" @value
  "inline" @inline
  "infix" @infix
  "final" @final
  "open" @open
  "const" @const
  "vararg" @vararg
  "expect" @expect
  "field" @field
  "file" @file
  "param" @param
  "fun" @fun
  "val" @val
  "var" @var
  "try" @try
  "for" @for
  "do" @do
  "as" @as
  "is" @is
  "in" @in
  "out" @out
  "get" @get
  "set" @set
  "by" @by
  "if" @if
}

*inside_keywords = {
  /return@[A-Za-z_][A-Za-z_0-9]*/ @return_at
  /continue@[A-Za-z_][A-Za-z_0-9]*/ @continue_at
  /break@[A-Za-z_][A-Za-z_0-9]*/ @break_at
  "continue" @continue
  "protected" @protected
  "internal" @internal
  "operator" @operator
  "override" @override
  "lateinit" @lateinit
  "noinline" @noinline
  "property" @property
  "setparam" @setparam
  "crossinline" @crossinline
  "annotation" @annotation
  "abstract" @abstract
  "private" @private
  "tailrec" @tailrec
  "external" @external
  "suspend" @suspend
  "reified" @reified
  "receiver" @receiver
  "delegate" @delegate
  "object" @object
  "super" @super
  "when" @when
  "throw" @throw
  "return" @return
  "break" @break
  "public" @public
  "sealed" @sealed
  "actual" @actual
  "else" @else
  "true" @boolean_literal
  "false" @boolean_literal
  "null" @null_literal
  "enum" @enum
  "data" @data
  "inner" @inner
  "value" @value
  "inline" @inline
  "infix" @infix
  "final" @final
  "open" @open
  "const" @const
  "vararg" @vararg
  "expect" @expect
  "field" @field
  "file" @file
  "param" @param
  "fun" @fun
  "val" @val
  "var" @var
  "try" @try
  "for" @for
  "do" @do
  "as" @as
  "is" @is
  "in" @in
  "out" @out
  "get" @get
  "set" @set
  "if" @if
}

*literals_and_identifiers = {
  /0[xX][0-9a-fA-F][0-9a-fA-F_]*[uU][lL]?/ @unsigned_literal
  /0[bB][01][01_]*[uU][lL]?/ @unsigned_literal
  /[1-9][0-9_]*[0-9][uU][lL]?/ @unsigned_literal
  /[0-9][uU][lL]?/ @unsigned_literal
  /0[xX][0-9a-fA-F][0-9a-fA-F_]*[lL]/ @long_literal
  /0[bB][01][01_]*[lL]/ @long_literal
  /[1-9][0-9_]*[0-9][lL]/ @long_literal
  /[0-9][lL]/ @long_literal
  /([0-9][0-9_]*)?\.[0-9][0-9_]*([eE][+\-]?[0-9][0-9_]*)?[fF]?/ @real_literal
  /[0-9][0-9_]*[eE][+\-]?[0-9][0-9_]*[fF]?/ @real_literal
  /[0-9][0-9_]*[fF]/ @real_literal
  /0[xX][0-9a-fA-F][0-9a-fA-F_]*/ @hex_literal
  /0[bB][01][01_]*/ @bin_literal
  /[1-9][0-9_]*[0-9]/ @integer_literal
  /[0-9]/ @integer_literal
  /'(\\u[0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F]|\\[tbrn'"\\$]|[^\n\r'\\])'/ @character_literal
  /[A-Za-z_][A-Za-z_0-9]*/ @identifier
  /`[^`\r\n]+`/ @identifier
}

*default_units = {
  /#![^\r\n]*/ @shebang_line
  line_string
  multiline_string
  delimited_comment
  /\/\/[^\r\n]*/ @line_comment
  parens
  brackets
  block
  *keywords
  *literals_and_identifiers
  *separators_and_operations
  /\r\n?/ @nl
  /\n/ @nl
  /[ \t\f]+/ @ws
}

*inside_units = {
  line_string
  multiline_string
  delimited_comment
  /\/\/[^\r\n]*/ @line_comment
  parens
  brackets
  block
  *inside_keywords
  *literals_and_identifiers
  *separators_and_operations
  /\r\n?/ @inside_nl
  /\n/ @inside_nl
  /[ \t\f]+/ @ws
}

main = {
  *default_units
  EOF .end
}

delimited_comment = /\/\*/ .begin @delimited_comment {
  delimited_comment
  /\*\// .end
  /[^*\/]+/
  /\*/
  /\//
}

block = /[{]/ .begin @lcurl {
  *default_units
  /[}]/ @rcurl .end
}

parens = /\(/ .begin @lparen {
  *inside_units
  /\)/ @rparen .end
}

brackets = /\[/ .begin @lsquare {
  *inside_units
  /\]/ @rsquare .end
}

line_string = /"/ .begin @quote_open {
  /"/ @quote_close .end
  line_str_expr
  /\$[A-Za-z_][A-Za-z_0-9]*/ @line_str_ref
  /\\u[0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F]/ @line_str_escaped_char
  /\\[tbrn'"\\$]/ @line_str_escaped_char
  /[^"\\$]+/ @line_str_text
  /\$/ @line_str_text
}

line_str_expr = /\$[{]/ .begin @line_str_expr_start {
  *default_units
  /[}]/ @rcurl .end
}

multiline_string = /"""/ .begin @triple_quote_open {
  /"{3,}/ @triple_quote_close .end
  multi_line_str_expr
  /\$[A-Za-z_][A-Za-z_0-9]*/ @multi_line_str_ref
  /"{1,2}/ @multi_line_str_text
  /[^"$]+/ @multi_line_str_text
  /\$/ @multi_line_str_text
}

multi_line_str_expr = /\$[{]/ .begin @multi_line_str_expr_start {
  *default_units
  /[}]/ @rcurl .end
}

[[peg]]

main = main_list
main_list = main_item*
main_item = [
  block : block
  parens : parens
  brackets : brackets
  line_string : line_string
  multiline_string : multiline_string
  main_token : main_token
]
main_token = default_token

line_string = @quote_open line_string_list @quote_close
line_string_list = line_string_item*
line_string_item = [
  line_str_expr : line_str_expr
  @line_str_ref : t_line_str_ref
  @line_str_text : t_line_str_text
  @line_str_escaped_char : t_line_str_escaped_char
]

block = TODO
parens = TODO
brackets = TODO
line_str_expr = TODO
multiline_string = TODO
multi_line_str_expr = TODO


default_token = [
  @shebang_line : t_shebang_line
  @nl : t_nl
  @reserved : t_reserved
  @dot : t_dot
  @comma : t_comma
  @mult : t_mult
  @mod : t_mod
  @div : t_div
  @add : t_add
  @sub : t_sub
  @incr : t_incr
  @decr : t_decr
  @conj : t_conj
  @disj : t_disj
  @excl_ws : t_excl_ws
  @excl_no_ws : t_excl_no_ws
  @colon : t_colon
  @semicolon : t_semicolon
  @assignment : t_assignment
  @add_assignment : t_add_assignment
  @sub_assignment : t_sub_assignment
  @mult_assignment : t_mult_assignment
  @div_assignment : t_div_assignment
  @mod_assignment : t_mod_assignment
  @arrow : t_arrow
  @double_arrow : t_double_arrow
  @range : t_range
  @range_until : t_range_until
  @coloncolon : t_coloncolon
  @double_semicolon : t_double_semicolon
  @hash : t_hash
  @at_no_ws : t_at_no_ws
  @at_post_ws : t_at_post_ws
  @at_pre_ws : t_at_pre_ws
  @at_both_ws : t_at_both_ws
  @quest_ws : t_quest_ws
  @quest_no_ws : t_quest_no_ws
  @langle : t_langle
  @rangle : t_rangle
  @le : t_le
  @ge : t_ge
  @excl_eq : t_excl_eq
  @excl_eqeq : t_excl_eqeq
  @as_safe : t_as_safe
  @eqeq : t_eqeq
  @eqeqeq : t_eqeqeq
  @single_quote : t_single_quote
  @amp : t_amp
  @return_at : t_return_at
  @continue_at : t_continue_at
  @break_at : t_break_at
  @this_at : t_this_at
  @super_at : t_super_at
  @file : t_file
  @field : t_field
  @property : t_property
  @get : t_get
  @set : t_set
  @receiver : t_receiver
  @param : t_param
  @setparam : t_setparam
  @delegate : t_delegate
  @package : t_package
  @import : t_import
  @class : t_class
  @interface : t_interface
  @fun : t_fun
  @object : t_object
  @val : t_val
  @var : t_var
  @type_alias : t_type_alias
  @constructor : t_constructor
  @by : t_by
  @companion : t_companion
  @init : t_init
  @this : t_this
  @super : t_super
  @typeof : t_typeof
  @where : t_where
  @if : t_if
  @else : t_else
  @when : t_when
  @try : t_try
  @catch : t_catch
  @finally : t_finally
  @for : t_for
  @do : t_do
  @while : t_while
  @throw : t_throw
  @return : t_return
  @continue : t_continue
  @break : t_break
  @as : t_as
  @is : t_is
  @in : t_in
  @out : t_out
  @dynamic : t_dynamic
  @public : t_public
  @private : t_private
  @protected : t_protected
  @internal : t_internal
  @enum : t_enum
  @sealed : t_sealed
  @annotation : t_annotation
  @data : t_data
  @inner : t_inner
  @value : t_value
  @tailrec : t_tailrec
  @operator : t_operator
  @inline : t_inline
  @infix : t_infix
  @external : t_external
  @suspend : t_suspend
  @override : t_override
