  @at_no_ws : t_at_no_ws
  @at_post_ws : t_at_post_ws
  @at_pre_ws : t_at_pre_ws
  @at_both_ws : t_at_both_ws
  @quest_ws : t_quest_ws
  @quest_no_ws : t_quest_no_ws
  @langle : t_langle
  @rangle : t_rangle
  @le : t_le
  @ge : t_ge
  @excl_eq : t_excl_eq
  @excl_eqeq : t_excl_eqeq
  @as_safe : t_as_safe
  @eqeq : t_eqeq
  @eqeqeq : t_eqeqeq
  @single_quote : t_single_quote
  @amp : t_amp
  @return_at : t_return_at
  @continue_at : t_continue_at
  @break_at : t_break_at
  @this_at : t_this_at
  @super_at : t_super_at
  @file : t_file
